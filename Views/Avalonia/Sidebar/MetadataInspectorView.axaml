<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels.Sidebar"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="700"
             x:Class="SLSKDONET.Views.Avalonia.Sidebar.MetadataInspectorView"
             x:DataType="vm:MetadataInspectorViewModel">

    <Border Background="#1C1C1E" BorderBrush="#3A3A3C" BorderThickness="1,0,0,0">
        <Grid RowDefinitions="Auto,*">

            <!-- Header -->
            <Border Grid.Row="0" Background="#2C2C2E" Padding="14,12"
                    BorderBrush="#3A3A3C" BorderThickness="0,0,0,1">
                <StackPanel Spacing="2">
                    <TextBlock Text="🔍 TRACK INFO" FontSize="10" FontWeight="Bold"
                               LetterSpacing="1.5" Foreground="#8E8E93"/>
                    <TextBlock Text="{Binding Title, FallbackValue='—'}"
                               FontSize="14" FontWeight="SemiBold"
                               TextWrapping="Wrap" MaxLines="2"/>
                    <TextBlock Text="{Binding Artist, FallbackValue='—'}"
                               FontSize="12" Foreground="#8E8E93"/>
                </StackPanel>
            </Border>

            <!-- Metadata Fields -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14,12" Spacing="12">

                    <!-- Key Info Row -->
                    <Grid ColumnDefinitions="*,*" >
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="KEY" FontSize="10" Foreground="#636366" FontWeight="Bold"/>
                            <TextBlock Text="{Binding MusicalKey, FallbackValue='—'}"
                                       FontSize="16" FontWeight="Bold" Foreground="#30D158"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="BPM" FontSize="10" Foreground="#636366" FontWeight="Bold"/>
                            <TextBlock Text="{Binding BpmDisplay, FallbackValue='—'}"
                                       FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>

                    <Separator/>

                    <!-- Fields -->
                    <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="Album" FontSize="12" Foreground="#8E8E93"/>
                            <TextBlock Grid.Column="1" Text="{Binding Album, FallbackValue='—'}"
                                       FontSize="12" TextWrapping="Wrap"/>
                        </Grid>
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="Genre" FontSize="12" Foreground="#8E8E93"/>
                            <TextBlock Grid.Column="1" Text="{Binding Genres, FallbackValue='—'}"
                                       FontSize="12" TextWrapping="Wrap"/>
                        </Grid>
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="Label" FontSize="12" Foreground="#8E8E93"/>
                            <TextBlock Grid.Column="1" Text="{Binding Label, FallbackValue='—'}"
                                       FontSize="12"/>
                        </Grid>
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="ISRC" FontSize="12" Foreground="#8E8E93"/>
                            <TextBlock Grid.Column="1" Text="{Binding Isrc, FallbackValue='—'}"
                                       FontSize="12" Foreground="#8E8E93"/>
                        </Grid>
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="Status" FontSize="12" Foreground="#8E8E93"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatusDisplay}"
                                       FontSize="12"/>
                        </Grid>
                        <Grid ColumnDefinitions="100,*">
                            <TextBlock Grid.Column="0" Text="Enriched" FontSize="12" Foreground="#8E8E93"/>
                            <TextBlock Grid.Column="1" Text="{Binding IsEnriched}"
                                       FontSize="12" Foreground="#30D158"/>
                        </Grid>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
