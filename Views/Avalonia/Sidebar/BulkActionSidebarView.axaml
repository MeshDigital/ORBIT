<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels.Sidebar"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="700"
             x:Class="SLSKDONET.Views.Avalonia.Sidebar.BulkActionSidebarView"
             x:DataType="vm:BulkActionSidebarViewModel">

    <Border Background="#1C1C1E" BorderBrush="#3A3A3C" BorderThickness="1,0,0,0">
        <Grid RowDefinitions="Auto,Auto,*">

            <!-- Header -->
            <Border Grid.Row="0" Background="#2C2C2E" Padding="14,12"
                    BorderBrush="#3A3A3C" BorderThickness="0,0,0,1">
                <StackPanel Spacing="2">
                    <TextBlock Text="☑️ BULK ACTIONS" FontSize="10" FontWeight="Bold"
                               LetterSpacing="1.5" Foreground="#8E8E93"/>
                    <TextBlock Text="{Binding SelectionSummary}" FontSize="14"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- Stats Row -->
            <Border Grid.Row="1" Background="#111112" Padding="14,10"
                    BorderBrush="#3A3A3C" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding SelectedCount}" FontSize="22"
                                   FontWeight="Bold" Foreground="#0A84FF" HorizontalAlignment="Center"/>
                        <TextBlock Text="Selected" FontSize="10" Foreground="#8E8E93" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding DownloadedCount}" FontSize="22"
                                   FontWeight="Bold" Foreground="#30D158" HorizontalAlignment="Center"/>
                        <TextBlock Text="Downloaded" FontSize="10" Foreground="#8E8E93" HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding MissingCount}" FontSize="22"
                                   FontWeight="Bold" Foreground="#FF9F0A" HorizontalAlignment="Center"/>
                        <TextBlock Text="Missing" FontSize="10" Foreground="#8E8E93" HorizontalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14,12" Spacing="8">

                    <TextBlock Text="LIBRARY" FontSize="10" FontWeight="Bold"
                               LetterSpacing="1" Foreground="#636366" Margin="0,0,0,4"/>

                    <Button Content="⬇️  Download Missing Tracks"
                            Command="{Binding DownloadMissingCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#0A84FF" Foreground="White"
                            Padding="12,10" CornerRadius="8"/>

                    <Button Content="🗑️  Remove Selected from Playlist"
                            Command="{Binding RemoveFromPlaylistCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#3A3A3C" Foreground="#FF453A"
                            Padding="12,10" CornerRadius="8"/>

                    <Separator Margin="0,8"/>

                    <TextBlock Text="METADATA" FontSize="10" FontWeight="Bold"
                               LetterSpacing="1" Foreground="#636366" Margin="0,0,0,4"/>

                    <Button Content="🏷️  Re-analyze Selected"
                            Command="{Binding ReAnalyzeCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#2C2C2E" Foreground="White"
                            Padding="12,10" CornerRadius="8"/>

                    <Button Content="🎨  Add to Smart Crate"
                            Command="{Binding AddToSmartCrateCommand}"
                            HorizontalAlignment="Stretch"
                            Background="#2C2C2E" Foreground="White"
                            Padding="12,10" CornerRadius="8"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
