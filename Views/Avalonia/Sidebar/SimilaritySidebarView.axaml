<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels.Sidebar"
             xmlns:rootvm="clr-namespace:SLSKDONET.ViewModels"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="700"
             x:Class="SLSKDONET.Views.Avalonia.Sidebar.SimilaritySidebarView"
             x:DataType="vm:SimilaritySidebarViewModel">

    <Border Background="#1C1C1E" BorderBrush="#3A3A3C" BorderThickness="1,0,0,0">
        <Grid RowDefinitions="Auto,Auto,*,Auto">

            <!-- Header: Seed Track -->
            <Border Grid.Row="0" Background="#2C2C2E" Padding="14,12"
                    BorderBrush="#3A3A3C" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="🧬 SIMILARITY" FontSize="10" FontWeight="Bold"
                                   LetterSpacing="1.5" Foreground="#8E8E93"/>
                        <TextBlock Text="{Binding SeedTitle, FallbackValue='—'}"
                                   FontSize="14" FontWeight="SemiBold"
                                   TextWrapping="Wrap" MaxLines="1"/>
                        <TextBlock Text="{Binding SeedArtist, FallbackValue='—'}"
                                   FontSize="12" Foreground="#8E8E93" MaxLines="1"/>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                            <Border Background="#3A3A3C" Padding="6,2" CornerRadius="4">
                                <TextBlock Text="{Binding SeedKey}" FontSize="11" Foreground="#30D158"/>
                            </Border>
                            <TextBlock Text="{Binding SeedBpmDisplay}" FontSize="11"
                                       Foreground="#8E8E93" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Loading spinner -->
                    <ProgressBar Grid.Column="1" IsIndeterminate="True"
                                 IsVisible="{Binding IsLoading}"
                                 Width="16" Height="16" VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <!-- Error / Empty state -->
            <Border Grid.Row="1" Padding="14,10" IsVisible="{Binding HasNoResults}">
                <TextBlock Text="No similar tracks found in your library."
                           FontSize="12" Foreground="#8E8E93" TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </Border>
            <Border Grid.Row="1" Padding="14,10"
                    IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="#FF453A"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- Match Results -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12,8" Spacing="4">

                    <!-- Harmonic Matches Section -->
                    <TextBlock Text="HARMONIC MATCHES" FontSize="10" FontWeight="Bold"
                               LetterSpacing="1" Foreground="#636366" Margin="0,4,0,6"
                               IsVisible="{Binding HarmonicMatches.Count, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                    <ItemsControl ItemsSource="{Binding HarmonicMatches}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="rootvm:HarmonicMatchViewModel">
                                <Border Margin="0,0,0,6" Padding="10" Background="#2C2C2E"
                                        CornerRadius="8" BorderBrush="#3A3A3C" BorderThickness="1">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="2">
                                            <TextBlock Text="{Binding TrackDisplay}" FontSize="13"
                                                       FontWeight="Medium" TextWrapping="Wrap" MaxLines="2"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                                                <Border Background="#3A3A3C" Padding="5,1" CornerRadius="3">
                                                    <TextBlock Text="{Binding Track.MusicalKey}"
                                                               FontSize="10" Foreground="#30D158"/>
                                                </Border>
                                                <TextBlock Text="{Binding BpmDisplay}" FontSize="10"
                                                           Foreground="#8E8E93" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                    HorizontalAlignment="Right" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding RelationshipIcon}" FontSize="16"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding ScoreDisplay}" FontSize="10"
                                                       FontWeight="Bold" HorizontalAlignment="Center"
                                                       Foreground="#30D158"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="3" Padding="14,8" Background="#111112"
                    BorderBrush="#3A3A3C" BorderThickness="0,1,0,0">
                <TextBlock Text="Based on key, BPM &amp; sonic profile" FontSize="10"
                           Foreground="#636366" HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
