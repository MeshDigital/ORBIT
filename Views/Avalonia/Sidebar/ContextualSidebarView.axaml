<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels.Sidebar"
             xmlns:sidebar="clr-namespace:SLSKDONET.Views.Avalonia.Sidebar"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="700"
             x:Class="SLSKDONET.Views.Avalonia.Sidebar.ContextualSidebarView"
             x:DataType="vm:ContextualSidebarViewModel">

    <UserControl.DataTemplates>
        <DataTemplate DataType="vm:SimilaritySidebarViewModel">
            <sidebar:SimilaritySidebarView/>
        </DataTemplate>
        <DataTemplate DataType="vm:BulkActionSidebarViewModel">
            <sidebar:BulkActionSidebarView/>
        </DataTemplate>
        <DataTemplate DataType="vm:MetadataInspectorViewModel">
            <sidebar:MetadataInspectorView/>
        </DataTemplate>
    </UserControl.DataTemplates>

    <!-- The shell: only visible when IsSidebarOpen -->
    <Border IsVisible="{Binding IsSidebarOpen}"
            Background="#1C1C1E"
            Width="300"
            BorderBrush="#3A3A3C"
            BorderThickness="1,0,0,0">

        <Grid RowDefinitions="Auto,*">
            <!-- Mode switcher tab strip -->
            <Border Grid.Row="0" Background="#111112" Padding="8,6"
                    BorderBrush="#3A3A3C" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button Content="Info"
                            IsEnabled="{Binding CanShowMetadata}"
                            Command="{Binding SwitchToMetadataCommand}"
                            FontSize="11" Padding="8,4" CornerRadius="6"
                            Background="#2C2C2E" Foreground="#EBEBF5"/>
                    <Button Content="Similarity"
                            IsEnabled="{Binding CanShowSimilarity}"
                            Command="{Binding SwitchToSimilarityCommand}"
                            FontSize="11" Padding="8,4" CornerRadius="6"
                            Background="#2C2C2E" Foreground="#EBEBF5"/>
                    <Button Content="Bulk"
                            IsEnabled="{Binding CanShowBulk}"
                            Command="{Binding SwitchToBulkCommand}"
                            FontSize="11" Padding="8,4" CornerRadius="6"
                            Background="#2C2C2E" Foreground="#EBEBF5"/>
                    <!-- Close button -->
                    <Button Content="✕" Command="{Binding CloseSidebarCommand}"
                            FontSize="11" Padding="8,4" CornerRadius="6"
                            Background="Transparent" Foreground="#636366"
                            HorizontalAlignment="Right" Margin="4,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Active content: DataTemplate dispatch resolves the right view -->
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentContent}"/>
        </Grid>
    </Border>
</UserControl>
