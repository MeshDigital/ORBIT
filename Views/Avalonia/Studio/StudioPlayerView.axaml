<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             xmlns:studio="clr-namespace:SLSKDONET.Views.Avalonia.Studio"
             x:Class="SLSKDONET.Views.Avalonia.Studio.StudioPlayerView"
             x:DataType="vm:PlayerViewModel">

    <Grid ColumnDefinitions="300, *, 300" Background="#1E1E1E">
        <!-- 1. TRACK INFO & TRANSPORT -->
        <Border Grid.Column="0" Padding="20" BorderBrush="#2D2D2D" BorderThickness="0,0,1,0">
            <StackPanel Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="{Binding TrackTitle}" Foreground="#00FFFF" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding TrackArtist}" Foreground="#888" FontSize="11" TextTrimming="CharacterEllipsis"/>
                
                <StackPanel Orientation="Horizontal" Spacing="15" Margin="0,10,0,0">
                    <Button Command="{Binding PreviousTrackCommand}" Background="Transparent" Padding="5">
                        <PathIcon Data="{StaticResource previous_regular}" Width="16" Foreground="#E0E0E0"/>
                    </Button>
                    <Button Command="{Binding TogglePlayPauseCommand}" Background="Transparent" Padding="5">
                        <PathIcon Data="{Binding IsPlaying, Converter={StaticResource BoolToPlayPauseIconConverter}}" Width="24" Foreground="#00FFFF"/>
                    </Button>
                    <Button Command="{Binding NextTrackCommand}" Background="Transparent" Padding="5">
                        <PathIcon Data="{StaticResource next_regular}" Width="16" Foreground="#E0E0E0"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 2. X-RAY WAVEFORM (THE HEART) -->
        <Grid Grid.Column="1" Margin="20,10">
            <Border Background="#121212" BorderBrush="#2D2D2D" BorderThickness="1" ClipToBounds="True">
                <Grid>
                    <!-- Hardware Accelerated X-Ray Waveform -->
                    <studio:StudioWaveformCanvas 
                        WaveformData="{Binding WaveformData}"
                        Phrases="{Binding Phrases}"
                        Cues="{Binding Cues}"
                        PlayheadPosition="{Binding Position}" />

                    <!-- Waveform Ghosting Overlay -->
                    <Border Background="#121212" IsVisible="{Binding IsExtractingWaveform}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10">
                            <ProgressBar IsIndeterminate="True" Width="200" Height="2" Foreground="#00FFFF" Background="#1E1E1E"/>
                            <TextBlock Text="EXTRACTING X-RAY PEAKS..." Foreground="#444" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
            
            <!-- Time Display -->
            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="5" Margin="0,0,10,5">
                 <TextBlock Text="{Binding CurrentTimeStr}" Foreground="#00FFFF" FontSize="10" FontWeight="Bold"/>
                 <TextBlock Text="/" Foreground="#444" FontSize="10"/>
                 <TextBlock Text="{Binding TotalTimeStr}" Foreground="#888" FontSize="10"/>
            </StackPanel>
        </Grid>

        <!-- 3. MASTER CONTROLS & GAIN -->
        <Border Grid.Column="2" Padding="20" BorderBrush="#2D2D2D" BorderThickness="1,0,0,0">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel VerticalAlignment="Center" Spacing="10">
                    <TextBlock Text="MASTER GAIN" FontSize="9" Foreground="#888" FontWeight="Bold" LetterSpacing="1"/>
                    <Slider Value="{Binding Volume}" Minimum="0" Maximum="100" Foreground="#00FFFF"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0" Spacing="10">
                     <Button Background="Transparent">
                        <PathIcon Data="{StaticResource speaker_2_regular}" Width="16" Foreground="#888"/>
                     </Button>
                     <Button Background="Transparent">
                        <PathIcon Data="{StaticResource arrow_repeat_all_regular}" Width="16" Foreground="#444"/>
                     </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
