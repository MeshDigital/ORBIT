<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SLSKDONET.Features.LibrarySidebar.ViewModels"
             x:Class="SLSKDONET.Views.Avalonia.Studio.StudioStemView"
             x:DataType="vm:StemSidebarViewModel">

    <Grid RowDefinitions="Auto,*">
        <!-- Stem Control Grid (DAW Style) -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="15" Spacing="15">
                <TextBlock Text="STEM SEPARATION" FontSize="10" FontWeight="Bold" Foreground="#888" LetterSpacing="1"/>
                
                <!-- Individual Stem Toggles -->
                <UniformGrid Columns="2" Rows="2">
                    <Grid RowDefinitions="Auto,Auto" Margin="5">
                        <TextBlock Text="VOCALS" FontSize="9" Foreground="#00FFFF" Margin="0,0,0,5"/>
                        <ToggleButton Grid.Row="1" IsChecked="{Binding IsVocalActive}" Height="40" Background="#121212" BorderBrush="#2D2D2D" BorderThickness="1">
                            <TextBlock Text="ACTIVE" FontSize="10" FontWeight="Bold"/>
                        </ToggleButton>
                    </Grid>

                    <Grid RowDefinitions="Auto,Auto" Margin="5">
                        <TextBlock Text="DRUMS" FontSize="9" Foreground="#B829EA" Margin="0,0,0,5"/>
                        <ToggleButton Grid.Row="1" IsChecked="{Binding IsDrumsActive}" Height="40" Background="#121212" BorderBrush="#2D2D2D" BorderThickness="1">
                            <TextBlock Text="ACTIVE" FontSize="10" FontWeight="Bold"/>
                        </ToggleButton>
                    </Grid>

                    <Grid RowDefinitions="Auto,Auto" Margin="5">
                        <TextBlock Text="BASS" FontSize="9" Foreground="#FFB000" Margin="0,0,0,5"/>
                        <ToggleButton Grid.Row="1" IsChecked="{Binding IsBassActive}" Height="40" Background="#121212" BorderBrush="#2D2D2D" BorderThickness="1">
                            <TextBlock Text="ACTIVE" FontSize="10" FontWeight="Bold"/>
                        </ToggleButton>
                    </Grid>

                    <Grid RowDefinitions="Auto,Auto" Margin="5">
                        <TextBlock Text="OTHER" FontSize="9" Foreground="#4CAF50" Margin="0,0,0,5"/>
                        <ToggleButton Grid.Row="1" IsChecked="{Binding IsOtherActive}" Height="40" Background="#121212" BorderBrush="#2D2D2D" BorderThickness="1">
                            <TextBlock Text="ACTIVE" FontSize="10" FontWeight="Bold"/>
                        </ToggleButton>
                    </Grid>
                </UniformGrid>

                <Border Background="#121212" Padding="15" BorderBrush="#2D2D2D" BorderThickness="1" Margin="5,10,5,0">
                    <StackPanel Spacing="10">
                        <TextBlock Text="PROCESSING STATUS" FontSize="9" Foreground="#444"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="4" Foreground="#00FFFF" Background="#2D2D2D"/>
                            <TextBlock Grid.Column="1" Text="{Binding StatusText}" FontSize="9" Foreground="#888" Margin="10,0,0,0"/>
                        </Grid>
                        <Button Content="GENERATE STEMS" Command="{Binding ProcessCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Background="#00FFFF" Foreground="Black" FontWeight="Bold" Padding="0,10"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
