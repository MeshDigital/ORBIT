<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SLSKDONET.Views"
        xmlns:views="clr-namespace:SLSKDONET.Views.Avalonia"
        xmlns:stemviews="clr-namespace:SLSKDONET.Views.Avalonia.Stem"
        xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
        xmlns:models="clr-namespace:SLSKDONET.Models"
        xmlns:sidebar="clr-namespace:SLSKDONET.Features.LibrarySidebar.Views"
        xmlns:vmSidebar="clr-namespace:SLSKDONET.Features.LibrarySidebar.ViewModels"
        xmlns:sidebarData="clr-namespace:SLSKDONET.Features.LibrarySidebar"
        xmlns:vmTimeline="clr-namespace:SLSKDONET.ViewModels.Timeline"
        xmlns:timeline="clr-namespace:SLSKDONET.Views.Avalonia.Timeline"
        xmlns:vmCore="clr-namespace:SLSKDONET.ViewModels"
        xmlns:data="clr-namespace:SLSKDONET.Data"
        xmlns:converters="clr-namespace:SLSKDONET.Views.Avalonia.Converters"
        mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
        x:Class="SLSKDONET.Views.Avalonia.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="ORBIT"
        Width="1400" Height="900"
        MinWidth="360" MinHeight="500"
        FontSize="{Binding BaseFontSize}"
        Background="#1E1E1E">

    <Window.Styles>
        <StyleInclude Source="/Themes/AvaloniaTheme.axaml"/>
        
        <!-- Navigation Sidebar Styles -->
        <Style Selector="Border.nav-sidebar">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Background" Value="{StaticResource DeepBackgroundBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.25" Easing="QuarticEaseOut"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.nav-sidebar.mini">
            <Setter Property="Width" Value="56"/>
        </Style>
        <Style Selector="Border.nav-sidebar.mini TextBlock:nth-child(2)">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="Border.nav-sidebar.mini Border.GroupHeader">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="Border.nav-sidebar.mini Button.nav StackPanel">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Spacing" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style Selector="Border.nav-sidebar.mini Button.nav">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Styles>
    
    <!-- Keyboard Shortcuts -->
    <Window.KeyBindings>
        <!-- Ctrl+F: Focus Search -->
        <KeyBinding Gesture="Ctrl+F" Command="{Binding NavigateSearchCommand}"/>
        
        <!-- Ctrl+L: Go to Library -->
        <KeyBinding Gesture="Ctrl+L" Command="{Binding NavigateLibraryCommand}"/>
        
        <!-- Ctrl+D: Go to Download Center -->
        <KeyBinding Gesture="Ctrl+D" Command="{Binding NavigateDownloadCenterCommand}"/>
        
        <!-- Ctrl+Shift+S: Go to Settings (Ctrl+S conflicts with save) -->
        <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding NavigateSettingsCommand}"/>
        
        <!-- Ctrl+Q: Quit -->
        <KeyBinding Gesture="Ctrl+Q" Command="{Binding QuitApplicationCommand}"/>
        
        <!-- Ctrl+P: Toggle Player -->
        <KeyBinding Gesture="Ctrl+P" Command="{Binding TogglePlayerCommand}"/>
        
        <!-- Ctrl+N: Toggle Navigation -->
        <KeyBinding Gesture="Ctrl+N" Command="{Binding ToggleNavigationCommand}"/>

        <!-- Ctrl+K: Command Palette -->
        <KeyBinding Gesture="Ctrl+K" Command="{Binding ToggleCommandPaletteCommand}"/>

        <!-- Global Navigation -->
        <KeyBinding Gesture="Ctrl+D1" Command="{Binding NavigateHomeCommand}"/>
        <KeyBinding Gesture="Ctrl+D2" Command="{Binding NavigateLibraryCommand}"/>
        <KeyBinding Gesture="Ctrl+D3" Command="{Binding NavigateSearchCommand}"/>
        <KeyBinding Gesture="Ctrl+D4" Command="{Binding NavigateDiscoveryHubCommand}"/>
        <KeyBinding Gesture="Ctrl+D5" Command="{Binding NavigateDownloadCenterCommand}"/>
        <KeyBinding Gesture="Ctrl+D6" Command="{Binding NavigateImportCommand}"/>
        <KeyBinding Gesture="Ctrl+D7" Command="{Binding NavigateInspectorCommand}"/>
        <KeyBinding Gesture="Ctrl+D8" Command="{Binding NavigateExportCommand}"/>

        <!-- F10: Zen Mode -->
        <KeyBinding Gesture="F10" Command="{Binding ToggleZenModeCommand}"/>
        
        <!-- F11: Toggle Top Bar -->
        <KeyBinding Gesture="F11" Command="{Binding ToggleTopBarCommand}"/>
    </Window.KeyBindings>
    
    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Unified Top Command Bar -->
        <Border Grid.Row="0" 
                Background="#1E1E1E" 
                Padding="12,10" 
                BorderBrush="#000" 
                BorderThickness="0,0,0,1"
                IsVisible="{Binding IsTopCommandBarVisible}">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Left: Navigation & Connection -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                    <Button Command="{Binding ToggleNavigationCommand}" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Padding="8,4"
                            ToolTip.Tip="Toggle Navigation">
                        <TextBlock Text="☰" FontSize="18" Foreground="#CCC"/>
                    </Button>
                    
                    <Border Background="#252526" CornerRadius="4" Padding="8,4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="8" Height="8" Fill="{Binding ConnectionViewModel.IsConnected, Converter={StaticResource BoolToColorConverter}}"
                                     ToolTip.Tip="Soulseek Connection Status"/>
                            <TextBlock Text="Soulseek" FontSize="11" Foreground="#999" VerticalAlignment="Center"/>
                            <Rectangle Width="1" Height="12" Fill="#444" Margin="4,0"/>
                            <Ellipse Width="8" Height="8" Fill="{Binding ConnectionViewModel.IsSpotifyConnected, Converter={StaticResource BoolToColorConverter}}"
                                     ToolTip.Tip="Spotify Connection Status"/>
                            <TextBlock Text="Spotify" FontSize="11" Foreground="#999" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Center: Mission Control (Activity Center) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                    <Button Command="{Binding ToggleIntelligenceCommand}" 
                            Background="#252526" 
                            BorderBrush="{Binding MissionControl.Health, Converter={StaticResource HealthToColorConverter}}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="12,4"
                            Height="32"
                            ToolTip.Tip="System Mission Control">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <!-- Health Icon -->
                            <TextBlock Text="{Binding MissionControl.Health, Converter={StaticResource HealthToIconConverter}}" 
                                       FontSize="14" 
                                       VerticalAlignment="Center"/>
                            
                            <!-- Status Summary -->
                            <TextBlock Text="{Binding MissionControl.StatusSummary}" 
                                       FontSize="12" 
                                       Foreground="#DDD" 
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            
                            <!-- Active Operations Badge -->
                            <Border Background="{Binding MissionControl.Health, Converter={StaticResource HealthToColorConverter}}"
                                    CornerRadius="10"
                                    MinWidth="20"
                                    Height="18"
                                    VerticalAlignment="Center"
                                    Padding="4,0"
                                    IsVisible="{Binding MissionControl.ActiveOperationsCount, Converter={StaticResource MoreThanZeroConverter}}">
                                 <TextBlock Text="{Binding MissionControl.ActiveOperationsCount}" 
                                            FontSize="10" 
                                            Foreground="Black" 
                                            FontWeight="Bold"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ExecuteBrainTestCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="4"
                            ToolTip.Tip="Run Smart Logic Verification"
                            VerticalAlignment="Center">
                        <TextBlock Text="🧠" FontSize="12" Opacity="0.5"/>
                    </Button>

                    <TextBlock Text="{Binding ApplicationVersion, StringFormat='v{0}'}" 
                               Foreground="#444"
                               FontSize="10"
                               VerticalAlignment="Center"
                               Margin="0"/>
                </StackPanel>

                <!-- Right: Activity Monitor & System Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="16">
                    <!-- Activity Monitor Group -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        
                        <!-- AI Stem Extraction (Acapella Factory) -->
                        <Grid IsVisible="{Binding MissionControl.IsStemQueueActive}" VerticalAlignment="Center">
                            <Grid.Styles>
                                <Style Selector="Grid">
                                    <Setter Property="Transitions">
                                        <Transitions>
                                            <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                                        </Transitions>
                                    </Setter>
                                </Style>
                            </Grid.Styles>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="✨ STEM ENGINE ACTIVE" 
                                           FontSize="11" 
                                           FontWeight="Bold" 
                                           Foreground="#B829EA" 
                                           VerticalAlignment="Center">
                                    <TextBlock.Styles>
                                        <Style Selector="TextBlock">
                                            <Style.Animations>
                                                <Animation Duration="0:0:1.5" IterationCount="Infinite">
                                                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                                </Animation>
                                            </Style.Animations>
                                        </Style>
                                    </TextBlock.Styles>
                                </TextBlock>
                                <TextBlock Text="{Binding MissionControl.StemQueueStatusText}" 
                                           FontFamily="Inter, Roboto, sans-serif" 
                                           FontWeight="Bold" 
                                           FontSize="11" 
                                           Foreground="#B829EA" 
                                           VerticalAlignment="Center"/>
                                <ProgressBar Value="{Binding MissionControl.StemQueueProgress}" 
                                             Maximum="1.0" 
                                             Height="4" 
                                             Width="80" 
                                             Foreground="#B829EA" 
                                             VerticalAlignment="Center"
                                             CornerRadius="2"/>

                                <Button Command="{Binding MissionControl.CancelStemQueueCommand}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="4"
                                        ToolTip.Tip="Cancel Stem Extraction"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="✕" FontSize="11" Foreground="#B829EA" Opacity="0.8"/>
                                </Button>
                                
                                <Rectangle Width="1" Height="16" Fill="#333" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Downloads -->
                        <StackPanel Orientation="Horizontal" Spacing="6" ToolTip.Tip="Downloads: In Progress / Completed / Failed">
                            <TextBlock Text="📥" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ActiveDownloadsCount}" Foreground="#4EC9B0" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="✓" FontSize="10" Foreground="#AAA" Margin="4,0,0,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding SuccessfulCount}" Foreground="#AAA" FontSize="11" VerticalAlignment="Center"/>
                            
                            <StackPanel Orientation="Horizontal" IsVisible="{Binding FailedCount}" Margin="4,0,0,0">
                                <TextBlock Text="⚠️" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding FailedCount}" Foreground="#F44336" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <Rectangle Width="1" Height="16" Fill="#333"/>

                        <!-- Analysis -->
                        <StackPanel Orientation="Horizontal" Spacing="6" ToolTip.Tip="Analysis Queue: Pending / Done">
                            <TextBlock Text="🧠" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding AnalysisQueueCount}" Foreground="#C586C0" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text="done" FontSize="10" Foreground="#666" VerticalAlignment="Bottom" Margin="2,0,0,1"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Height="20" Background="#404040"/>

                    <!-- System Controls -->
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <!-- Condensed Zoom -->
                        <Button Command="{Binding ZoomOutCommand}" Background="Transparent" BorderThickness="0" Padding="4" ToolTip.Tip="Zoom Out">
                            <TextBlock Text="🔍-" FontSize="12" Foreground="#888"/>
                        </Button>
                        <TextBlock Text="{Binding UIScalePercentage}" Foreground="#666" FontSize="10" VerticalAlignment="Center" MinWidth="30" TextAlignment="Center"/>
                        <Button Command="{Binding ZoomInCommand}" Background="Transparent" BorderThickness="0" Padding="4" ToolTip.Tip="Zoom In">
                            <TextBlock Text="🔍+" FontSize="12" Foreground="#888"/>
                        </Button>

                        <Rectangle Width="1" Height="16" Fill="#333" Margin="4,0"/>

                        <Button Command="{Binding TogglePlayerCommand}" 
                                Background="Transparent" 
                                BorderThickness="0" 
                                Padding="6,4"
                                ToolTip.Tip="Toggle Music Player">
                            <TextBlock Text="🎵" Foreground="{Binding IsPlayerSidebarVisible, Converter={StaticResource ActiveColorConverter}}" FontSize="14"/>
                        </Button>
                        
                        <Button Command="{Binding TogglePlayerLocationCommand}" 
                                Background="Transparent" 
                                BorderThickness="0" 
                                Padding="6,4"
                                ToolTip.Tip="Switch Player Location (Sidebar/Bottom)">
                            <TextBlock Text="{Binding IsPlayerAtBottom, Converter={StaticResource PlayerDockIconConverter}}" 
                                       FontSize="14" Foreground="#A0A0A0"/>
                        </Button>
                        
                        <Button Command="{Binding NavigateSettingsCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="6,4"
                                ToolTip.Tip="Settings">
                            <TextBlock Text="⚙️" FontSize="14" Foreground="#A0A0A0"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area: 4-Zone DAW Layout -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,4,*,4,Auto">
            
            <!-- Zone 1: Navigator (Left Sidebar) -->
            <Border Grid.Column="0" 
                    Background="{StaticResource DeepBackgroundBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    Classes="nav-sidebar"
                    Classes.mini="{Binding IsNavigationMini}">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Show ACQUIRE" IsChecked="{Binding IsAcquireVisible}" ToggleType="CheckBox"/>
                        <MenuItem Header="Show ENRICH" IsChecked="{Binding IsEnrichVisible}" ToggleType="CheckBox"/>
                        <MenuItem Header="Show CURATE" IsChecked="{Binding IsCurateVisible}" ToggleType="CheckBox"/>
                        <MenuItem Header="Show DELIVER" IsChecked="{Binding IsDeliverVisible}" ToggleType="CheckBox"/>
                        <MenuItem Header="Show SYSTEM" IsChecked="{Binding IsSystemVisible}" ToggleType="CheckBox"/>
                        <Separator/>
                        <MenuItem Header="Zen Mode (F10)" IsChecked="{Binding IsZenMode}" ToggleType="CheckBox"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <ScrollViewer>
                    <StackPanel Margin="0,16,0,0" Spacing="8">
                        
                        <!-- ACQUIRE -->
                        <StackPanel IsVisible="{Binding IsAcquireVisible}">
                            <Border Classes="GroupHeader" Padding="16,8,0,4">
                                <TextBlock Text="ACQUIRE" Classes="GroupTitle" FontSize="11" FontWeight="Bold" Foreground="#666" LetterSpacing="1"/>
                            </Border>
                            
                            <StackPanel Spacing="2">
                                <Button Classes="nav" Command="{Binding NavigateSearchCommand}"
                                        ToolTip.Tip="Search"
                                        Classes.selected="{Binding Workspace.CurrentContext, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:WorkspaceContext.SoulseekSearch}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="🔍" FontSize="16"/>
                                        <TextBlock Text="Search" FontSize="14"/>
                                    </StackPanel>
                                </Button>

                                <Button Classes="nav" Command="{Binding NavigateDiscoveryHubCommand}"
                                        ToolTip.Tip="Discovery Hub"
                                        Classes.selected="{Binding CurrentPageType, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:PageType.DiscoveryHub}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="🛸" FontSize="16"/>
                                        <TextBlock Text="Discovery Hub" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                                
                                <Button Classes="nav" Command="{Binding NavigateDownloadCenterCommand}"
                                        ToolTip.Tip="Download Center"
                                        Classes.selected="{Binding CurrentPageType, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:PageType.Projects}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="📥" FontSize="16"/>
                                        <TextBlock Text="Download Center" FontSize="14"/>
                                    </StackPanel>
                                </Button>

                                <Button Classes="nav" Command="{Binding NavigateImportCommand}"
                                        ToolTip.Tip="Import"
                                        Classes.selected="{Binding Workspace.CurrentContext, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:WorkspaceContext.SpotifyImport}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="🔗" FontSize="16"/>
                                        <TextBlock Text="Import" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- ENRICH -->
                        <StackPanel IsVisible="{Binding IsEnrichVisible}">
                            <Border Classes="GroupHeader" Padding="16,8,0,4">
                                <TextBlock Text="ENRICH" Classes="GroupTitle" FontSize="11" FontWeight="Bold" Foreground="#666" LetterSpacing="1"/>
                            </Border>

                            <StackPanel Spacing="2">
                                <Button Classes="nav" Command="{Binding NavigateInspectorCommand}"
                                        ToolTip.Tip="Engine Stats"
                                        Classes.selected="{Binding CurrentPageType, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:PageType.AnalysisQueue}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="🧠" FontSize="16"/>
                                        <TextBlock Text="Engine Stats" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- CURATE -->
                        <StackPanel IsVisible="{Binding IsCurateVisible}">
                            <Border Classes="GroupHeader" Padding="16,8,0,4">
                                <TextBlock Text="CURATE" Classes="GroupTitle" FontSize="11" FontWeight="Bold" Foreground="#666" LetterSpacing="1"/>
                            </Border>

                            <StackPanel Spacing="2">
                                <Button Classes="nav" Command="{Binding NavigateExportCommand}"
                                        ToolTip.Tip="Export Manager"
                                        Classes.selected="{Binding CurrentPageType, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:PageType.Export}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="🚀" FontSize="16"/>
                                        <TextBlock Text="Export Manager" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- DELIVER -->
                        <StackPanel IsVisible="{Binding IsDeliverVisible}">
                            <Border Classes="GroupHeader" Padding="16,8,0,4">
                                <TextBlock Text="DELIVER" Classes="GroupTitle" FontSize="11" FontWeight="Bold" Foreground="#666" LetterSpacing="1"/>
                            </Border>

                            <StackPanel Spacing="2">
                                <Button Classes="nav" Command="{Binding NavigateExportCommand}"
                                        ToolTip.Tip="Export Manager"
                                        Classes.selected="{Binding CurrentPageType, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:PageType.Export}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="🚀" FontSize="16"/>
                                        <TextBlock Text="Export Manager" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <Border Height="1" Background="#333" Margin="12,12"/>

                        <!-- SYSTEM UTILITIES -->
                        <StackPanel IsVisible="{Binding IsSystemVisible}">
                            <Border Classes="GroupHeader" Padding="16,8,0,4">
                                <TextBlock Text="SYSTEM" Classes="GroupTitle" FontSize="11" FontWeight="Bold" Foreground="#666" LetterSpacing="1"/>
                            </Border>

                            <StackPanel Spacing="2">
                                 <Button Classes="nav" Command="{Binding NavigateHomeCommand}"
                                        ToolTip.Tip="Dashboard"
                                        Classes.selected="{Binding Workspace.CurrentContext, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:WorkspaceContext.LocalLibrary}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="🏠" FontSize="16"/>
                                        <TextBlock Text="Dashboard" FontSize="14"/>
                                    </StackPanel>
                                </Button>

                                <Button Classes="nav" Command="{Binding NavigateLibraryCommand}"
                                        ToolTip.Tip="Library"
                                        Classes.selected="{Binding Workspace.CurrentContext, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:WorkspaceContext.LocalLibrary}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="📚" FontSize="16"/>
                                        <TextBlock Text="Library" FontSize="14"/>
                                    </StackPanel>
                                </Button>

                                <Button Classes="nav" Command="{Binding NavigateUpgradeScoutCommand}"
                                        ToolTip.Tip="Upgrades"
                                        Classes.selected="{Binding CurrentPageType, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:PageType.UpgradeScout}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="💎" FontSize="16"/>
                                        <TextBlock Text="Upgrades" FontSize="14"/>
                                    </StackPanel>
                                </Button>

                                <Button Classes="nav" Command="{Binding NavigateSettingsCommand}"
                                        ToolTip.Tip="Settings"
                                        Classes.selected="{Binding CurrentPageType, Converter={StaticResource EqualityConverter}, ConverterParameter={x:Static models:PageType.Settings}}">
                                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0">
                                        <TextBlock Text="⚙️" FontSize="16"/>
                                        <TextBlock Text="Settings" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Zone 2: Navigator Splitter -->
            <GridSplitter Grid.Column="1" Background="Transparent" Width="4" HorizontalAlignment="Stretch"/>

            <!-- Zone 3: Canvas (Center Content Area) -->
            <Border Grid.Column="2" Background="#1E1E1E">
                <TransitioningContentControl Content="{Binding CurrentPage}">
                    <TransitioningContentControl.PageTransition>
                        <CrossFade Duration="0:0:0.25"/>
                    </TransitioningContentControl.PageTransition>
                </TransitioningContentControl>
            </Border>

            <!-- Zone 4: Inspector Splitter -->
            <GridSplitter Grid.Column="3" Background="Transparent" Width="4" HorizontalAlignment="Stretch"/>

            <!-- Zone 5: Inspector (Right Sidebar) -->
            <Border Grid.Column="4" 
                    Background="#252526" 
                    BorderBrush="#3E3E3E" 
                    BorderThickness="1,0,0,0" 
                    Width="320"
                    BoxShadow="{Binding Player.CurrentTrack.CamelotKey, Converter={StaticResource CamelotToGlowConverter}}">
                <Border.Resources>
                    <converters:EnumToBooleanConverter x:Key="NotPlayerModeConverter" Negate="True" />
                </Border.Resources>
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Padding="8,4" Background="#1E1E1E" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <Grid ColumnDefinitions="*,Auto" Margin="4,0,4,4">
                                <TextBlock Text="{Binding Sidebar.ModeLabel}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" Foreground="#888" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                    <Button Classes="tool" Command="{Binding Sidebar.ShowPlayerCommand}" ToolTip.Tip="Show Player">
                                        <TextBlock Text="🎵" FontSize="12"/>
                                    </Button>
                                    <Button Classes="tool" Command="{Binding Sidebar.HideCommand}" Content="✖" Foreground="#666"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- DAW Intelligence Tabs -->
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                          IsVisible="{Binding Sidebar.ActiveMode, Converter={StaticResource NotPlayerModeConverter}, ConverterParameter={x:Static sidebarData:LibrarySidebarMode.Player}}">
                                <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,0,0,4">
                                    <Button Classes="tab" Command="{Binding Sidebar.SetModeCommand}" CommandParameter="{x:Static sidebarData:LibrarySidebarMode.Similarity}" ToolTip.Tip="Similarity Discovery">
                                        <TextBlock Text="🎯" Opacity="{Binding Sidebar.ActiveMode, Converter={StaticResource EnumToOpacityConverter}, ConverterParameter={x:Static sidebarData:LibrarySidebarMode.Similarity}}"/>
                                    </Button>
                                    <Button Classes="tab" Command="{Binding Sidebar.SetModeCommand}" CommandParameter="{x:Static sidebarData:LibrarySidebarMode.Cues}" ToolTip.Tip="Cue Points &amp; Phrases">
                                        <TextBlock Text="📍" Opacity="{Binding Sidebar.ActiveMode, Converter={StaticResource EnumToOpacityConverter}, ConverterParameter={x:Static sidebarData:LibrarySidebarMode.Cues}}"/>
                                    </Button>
                                    <Button Classes="tab" Command="{Binding Sidebar.SetModeCommand}" CommandParameter="{x:Static sidebarData:LibrarySidebarMode.Stems}" ToolTip.Tip="STEMS Explorer">
                                        <TextBlock Text="🎛️" Opacity="{Binding Sidebar.ActiveMode, Converter={StaticResource EnumToOpacityConverter}, ConverterParameter={x:Static sidebarData:LibrarySidebarMode.Stems}}"/>
                                    </Button>
                                    <Button Classes="tab" Command="{Binding Sidebar.SetModeCommand}" CommandParameter="{x:Static sidebarData:LibrarySidebarMode.VibeLab}" ToolTip.Tip="Vibe Radar">
                                        <TextBlock Text="🎭" Opacity="{Binding Sidebar.ActiveMode, Converter={StaticResource EnumToOpacityConverter}, ConverterParameter={x:Static sidebarData:LibrarySidebarMode.VibeLab}}"/>
                                    </Button>
                                    <Button Classes="tab" Command="{Binding Sidebar.SetModeCommand}" CommandParameter="{x:Static sidebarData:LibrarySidebarMode.TransitionProber}" ToolTip.Tip="Transition Prober">
                                        <TextBlock Text="🔄" Opacity="{Binding Sidebar.ActiveMode, Converter={StaticResource EnumToOpacityConverter}, ConverterParameter={x:Static sidebarData:LibrarySidebarMode.TransitionProber}}"/>
                                    </Button>
                                    <Button Classes="tab" Command="{Binding Sidebar.SetModeCommand}" CommandParameter="{x:Static sidebarData:LibrarySidebarMode.Forensic}" ToolTip.Tip="Forensic Repair">
                                        <TextBlock Text="🔬" Opacity="{Binding Sidebar.ActiveMode, Converter={StaticResource EnumToOpacityConverter}, ConverterParameter={x:Static sidebarData:LibrarySidebarMode.Forensic}}"/>
                                    </Button>
                                    <Button Classes="tab" Command="{Binding Sidebar.SetModeCommand}" CommandParameter="{x:Static sidebarData:LibrarySidebarMode.Metadata}" ToolTip.Tip="Full Metadata Inspector">
                                        <TextBlock Text="🏷️" Opacity="{Binding Sidebar.ActiveMode, Converter={StaticResource EnumToOpacityConverter}, ConverterParameter={x:Static sidebarData:LibrarySidebarMode.Metadata}}"/>
                                    </Button>
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                    
                    <ContentControl Grid.Row="1" Content="{Binding Sidebar.CurrentContent}">
                        <ContentControl.DataTemplates>
                            <DataTemplate DataType="vmSidebar:SimilaritySidebarViewModel">
                                <sidebar:SimilaritySidebarView/>
                            </DataTemplate>
                            <DataTemplate DataType="vmSidebar:BulkActionSidebarViewModel">
                                <sidebar:BulkActionSidebarView/>
                            </DataTemplate>
                            <DataTemplate DataType="vmSidebar:ForensicSidebarViewModel">
                                <sidebar:ForensicSidebarView/>
                            </DataTemplate>
                            <DataTemplate DataType="vmSidebar:MetadataSidebarViewModel">
                                <sidebar:MetadataSidebarView/>
                            </DataTemplate>
                            <DataTemplate DataType="vmSidebar:CueSidebarViewModel">
                                <sidebar:CueSidebarView/>
                            </DataTemplate>
                            <DataTemplate DataType="vmSidebar:StemSidebarViewModel">
                                <sidebar:StemSidebarView/>
                            </DataTemplate>
                            <DataTemplate DataType="vmSidebar:VibeSidebarViewModel">
                                <sidebar:VibeSidebarView/>
                            </DataTemplate>
                            <DataTemplate DataType="vmSidebar:TransitionProberViewModel">
                                <sidebar:TransitionProberView/>
                            </DataTemplate>
                            <DataTemplate DataType="vmCore:PlayerViewModel">
                                <views:PlayerControl/>
                            </DataTemplate>
                        </ContentControl.DataTemplates>
                    </ContentControl>
                </Grid>
            </Border>

        </Grid>

        <!-- Login Overlay -->
        <Grid Grid.RowSpan="3" 
              Background="#DD000000" 
              IsVisible="{Binding ConnectionViewModel.IsLoginOverlayVisible}" 
              ZIndex="1000">
            <Border Background="#252526" 
                    CornerRadius="8" 
                    Padding="32"
                    Width="420"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    BorderBrush="#404040"
                    BorderThickness="1">
                <StackPanel Spacing="12">
                    <TextBlock Text="Sign in to Soulseek" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               Margin="0,0,0,12"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Username" Foreground="#A0A0A0" FontSize="12"/>
                    <TextBox Text="{Binding ConnectionViewModel.Username, Mode=TwoWay}" 
                             Watermark="Username"
                             Padding="12,8"
                             FontSize="14"/>

                    <TextBlock Text="Password" Foreground="#A0A0A0" FontSize="12"/>
                    <TextBox x:Name="LoginPasswordBox" 
                             Watermark="Password"
                             PasswordChar="●"
                             Padding="12,8"
                             FontSize="14"/>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <CheckBox Content="Remember me" 
                                  IsChecked="{Binding ConnectionViewModel.RememberPassword, Mode=TwoWay}" 
                                  Foreground="White"/>
                        <CheckBox Content="Auto-connect" 
                                  IsChecked="{Binding ConnectionViewModel.AutoConnectEnabled, Mode=TwoWay}" 
                                  Foreground="White"/>
                    </StackPanel>

                    <Button Classes="primary"
                            Content="Connect" 
                            Command="{Binding ConnectionViewModel.LoginCommand}" 
                            CommandParameter="{Binding #LoginPasswordBox.Text}"
                            Height="44"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Margin="0,8,0,0"/>
                    
                    <Button Content="Maybe Later" 
                            Command="{Binding ConnectionViewModel.DismissLoginCommand}"
                            Background="Transparent" 
                            Foreground="#A0A0A0" 
                            FontSize="12"
                            BorderThickness="0" 
                            Padding="0,12"
                            HorizontalContentAlignment="Center">
                        <Button.Styles>
                            <Style Selector="Button:pointerover">
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </Button.Styles>
                    </Button>

                    <TextBlock Text="{Binding ConnectionViewModel.StatusText}" 
                               Foreground="#FFB347" 
                               FontSize="12" 
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
        
        <!-- Zone 6: Performance Master (Bottom Dock) -->
        <Border Grid.Row="2" 
                Background="#252526" 
                BorderBrush="#3E3E3E" 
                BorderThickness="0,1,0,0"
                Height="{Binding PerformanceDockHeight}"
                IsVisible="{Binding IsPerformanceDockVisible}">
            <Grid>
                <!-- Compact Player Mode -->
                <ContentControl IsVisible="{Binding PerformanceDockMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static data:PerformanceDockMode.CompactPlayer}}"
                              Content="{Binding PlayerViewModel}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <views:HorizontalPlayerControl/>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

                <!-- Full Designer Mode -->
                <ContentControl IsVisible="{Binding PerformanceDockMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static data:PerformanceDockMode.FullDesigner}}"
                              Content="{Binding SetDesignerViewModel}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <timeline:SetDesignerView/>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>

                <!-- Zone Toggles (Always visible if dock is open) -->
                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="4,4,16,4" Orientation="Horizontal" Spacing="4">
                    <Button Classes="tab" ToolTip.Tip="Toggle Compact Player" 
                            Command="{Binding SetPerformanceDockModeCommand}"
                            CommandParameter="{x:Static data:PerformanceDockMode.CompactPlayer}">
                        <TextBlock Text="🎵" Opacity="{Binding PerformanceDockMode, Converter={StaticResource EnumToOpacityConverter}, ConverterParameter={x:Static data:PerformanceDockMode.CompactPlayer}}"/>
                    </Button>
                    <Button Classes="tab" ToolTip.Tip="Toggle Performance Designer" 
                            Command="{Binding SetPerformanceDockModeCommand}"
                            CommandParameter="{x:Static data:PerformanceDockMode.FullDesigner}">
                        <TextBlock Text="📉" Opacity="{Binding PerformanceDockMode, Converter={StaticResource EnumToOpacityConverter}, ConverterParameter={x:Static data:PerformanceDockMode.FullDesigner}}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stem Workspace Overlay -->
        <Grid Grid.RowSpan="3"
            IsVisible="{Binding StemWorkspaceViewModel.IsVisible}"
            ZIndex="1500">
            <stemviews:StemWorkspaceView DataContext="{Binding StemWorkspaceViewModel}"/>
        </Grid>
        
        <!-- Global Bulk Operation Progress Overlay -->

        <controls:BulkOperationProgressModal Grid.RowSpan="3"
                                            DataContext="{Binding BulkOperationViewModel}"
                                            ZIndex="2000"/>

        <!-- Operation Glass Console Overlay -->
        <views:IntelligenceCenterView Grid.RowSpan="3"
                                    DataContext="{Binding IntelligenceCenter}"
                                    ZIndex="2500"/>

        <!-- Command Palette Overlay -->
        <views:CommandPaletteView Grid.RowSpan="3"
                                DataContext="{Binding CommandPaletteViewModel}"
                                ZIndex="3000"/>

        </Grid>
</Window>
