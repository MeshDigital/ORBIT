<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SLSKDONET.Views.Avalonia.Controls.GrandPianoControl"
             MinHeight="150" MinWidth="400">
    
    <UserControl.Styles>
        <Style Selector="Button.white-key">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0,0,4,4"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.white-key:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#E0E0E0"/>
        </Style>
        <Style Selector="Button.white-key:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#D0D0D0"/>
        </Style>

        <Style Selector="Button.black-key">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="BorderBrush" Value="#000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="0,0,2,2"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Height" Value="90"/>
            <Setter Property="ZIndex" Value="10"/>
        </Style>
        <Style Selector="Button.black-key:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#444"/>
        </Style>
        <Style Selector="Button.black-key:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#111"/>
        </Style>
    </UserControl.Styles>

    <Border Background="#1A1A1A" BorderBrush="#333" BorderThickness="1" CornerRadius="4" Padding="8">
        <Grid>
            <!-- White Keys Background Grid -->
            <!-- 14 White Keys for 2 Octaves -->
            <UniformGrid Columns="14">
                <Button Classes="white-key" Tag="C3" Click="OnKeyClicked"/>
                <Button Classes="white-key" Tag="D3" Click="OnKeyClicked"/>
                <Button Classes="white-key" Tag="E3" Click="OnKeyClicked"/>
                <Button Classes="white-key" Tag="F3" Click="OnKeyClicked"/>
                <Button Classes="white-key" Tag="G3" Click="OnKeyClicked"/>
                <Button Classes="white-key" Tag="A3" Click="OnKeyClicked"/>
                <Button Classes="white-key" Tag="B3" Click="OnKeyClicked"/>
                
                <Button Classes="white-key" Tag="C4" Click="OnKeyClicked"/>
                <Button Classes="white-key" Tag="D4" Click="OnKeyClicked"/>
                <Button Classes="white-key" Tag="E4" Click="OnKeyClicked"/>
                <Button Classes="white-key" Tag="F4" Click="OnKeyClicked"/>
                <Button Classes="white-key" Tag="G4" Click="OnKeyClicked"/>
                <Button Classes="white-key" Tag="A4" Click="OnKeyClicked"/>
                <Button Classes="white-key" Tag="B4" Click="OnKeyClicked"/>
            </UniformGrid>

            <!-- Black Keys Overlay Grid -->
            <!-- We use a grid with 28 columns (half-steps basically) so black keys can span -->
            <UniformGrid Columns="28" Margin="0,0,0,0">
                <!-- Octave 1 -->
                <Panel/><Button Classes="black-key" Tag="C#3" Click="OnKeyClicked" Margin="-10,0,-10,0"/>
                <Panel/><Button Classes="black-key" Tag="D#3" Click="OnKeyClicked" Margin="-10,0,-10,0"/>
                <Panel/><Panel/> <!-- E to F has no black key -->
                <Panel/><Button Classes="black-key" Tag="F#3" Click="OnKeyClicked" Margin="-10,0,-10,0"/>
                <Panel/><Button Classes="black-key" Tag="G#3" Click="OnKeyClicked" Margin="-10,0,-10,0"/>
                <Panel/><Button Classes="black-key" Tag="A#3" Click="OnKeyClicked" Margin="-10,0,-10,0"/>
                <Panel/><Panel/> <!-- B to C -->
                
                <!-- Octave 2 -->
                <Panel/><Button Classes="black-key" Tag="C#4" Click="OnKeyClicked" Margin="-10,0,-10,0"/>
                <Panel/><Button Classes="black-key" Tag="D#4" Click="OnKeyClicked" Margin="-10,0,-10,0"/>
                <Panel/><Panel/>
                <Panel/><Button Classes="black-key" Tag="F#4" Click="OnKeyClicked" Margin="-10,0,-10,0"/>
                <Panel/><Button Classes="black-key" Tag="G#4" Click="OnKeyClicked" Margin="-10,0,-10,0"/>
                <Panel/><Button Classes="black-key" Tag="A#4" Click="OnKeyClicked" Margin="-10,0,-10,0"/>
                <Panel/><Panel/>
            </UniformGrid>
        </Grid>
    </Border>
</UserControl>
