<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels.Downloads"
             xmlns:m="clr-namespace:SLSKDONET.Models"
             xmlns:c="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
             x:Class="SLSKDONET.Views.Avalonia.DownloadsPage"
             x:DataType="vm:DownloadCenterViewModel"
             Background="#1E1E1E" Foreground="White">
    
    <UserControl.Styles>
        <Style Selector="Border.express">
             <Setter Property="BorderBrush" Value="#FFD700"/>
             <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <!-- Golden Row Template -->
        <DataTemplate x:Key="DownloadItemTemplate" DataType="vm:UnifiedTrackViewModel">
            <Border Background="Transparent">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Play" Command="{Binding PlayCommand}" IsVisible="{Binding IsCompleted}"><MenuItem.Icon><PathIcon Data="{StaticResource play_circle_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="Show in Explorer" Command="{Binding RevealFileCommand}" IsVisible="{Binding IsCompleted}"><MenuItem.Icon><PathIcon Data="{StaticResource folder_open_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="Add to Project" Command="{Binding AddToProjectCommand}" IsVisible="{Binding IsCompleted}"><MenuItem.Icon><PathIcon Data="{StaticResource add_circle_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                        <Separator/>
                        <MenuItem Header="Retry Download" Command="{Binding RetryCommand}" IsVisible="{Binding IsFailed}"><MenuItem.Icon><PathIcon Data="{StaticResource arrow_counterclockwise_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="Remove from History" Command="{Binding CleanCommand}"><MenuItem.Icon><PathIcon Data="{StaticResource delete_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>
                <c:StandardTrackRow Classes="card"/>
            </Border>
        </DataTemplate>
        <!-- Failed Row Template -->
        <DataTemplate x:Key="FailedDownloadItemTemplate" DataType="vm:UnifiedTrackViewModel">
             <Border Background="Transparent" Margin="0,0,0,8">
                 <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Retry Download" Command="{Binding RetryCommand}"><MenuItem.Icon><PathIcon Data="{StaticResource arrow_counterclockwise_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="View All Search Results" Command="{Binding ViewAllSearchResultsCommand}"><MenuItem.Icon><PathIcon Data="{StaticResource search_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                        <MenuItem Header="Remove from History" Command="{Binding CleanCommand}"><MenuItem.Icon><PathIcon Data="{StaticResource delete_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                        <Separator/>
                        <MenuItem Header="Copy Failure Log" Command="{Binding CopyLogCommand}"><MenuItem.Icon><PathIcon Data="{StaticResource copy_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                    </ContextMenu>
                </Border.ContextMenu>
                
                <Border Background="#252526" CornerRadius="6" Padding="12" BorderBrush="#333" BorderThickness="1">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <!-- Header -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding TrackTitle}" FontWeight="Bold" Foreground="White" />
                                <TextBlock Text="•" Foreground="#444"/>
                                <TextBlock Text="{Binding ArtistName}" Foreground="#AAA" />
                            </StackPanel>
                            
                            <!-- Diagnostics -->
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <!-- Error Badge -->
                                <Border Background="#2C1F1F" CornerRadius="4" Padding="8,4" BorderBrush="#501B1B" BorderThickness="1">
                                     <StackPanel Orientation="Horizontal" Spacing="6">
                                         <TextBlock Text="⚠️" FontSize="10" VerticalAlignment="Center"/>
                                         <TextBlock Text="{Binding FailureDisplayMessage}" Foreground="#FF5252" FontSize="11" FontWeight="SemiBold"/>
                                     </StackPanel>
                                </Border>
                                
                                <!-- Suggestion -->
                                <TextBlock Text="{Binding FailureActionSuggestion}" 
                                           Foreground="#888" 
                                           FontSize="11" 
                                           VerticalAlignment="Center"
                                           FontStyle="Italic"/>
                            </StackPanel>

                            <!-- Phase 0.5: Detailed Rejection Reasons -->
                            <StackPanel IsVisible="{Binding HasRejectionDetails}" Margin="0,8,0,0">
                                 <TextBlock Text="Top Rejection Reasons:" FontSize="10" Foreground="#666" Margin="0,0,0,2"/>
                                 <ItemsControl ItemsSource="{Binding RejectionDetails}">
                                     <ItemsControl.ItemTemplate>
                                         <DataTemplate>
                                             <Grid ColumnDefinitions="20, *" RowDefinitions="Auto, Auto" Margin="0,3">
                                                 <!-- Rank -->
                                                 <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Rank, StringFormat='{}#{0}'}" Foreground="#555" FontSize="11" VerticalAlignment="Top" Margin="0,1,0,0"/>
                                                 
                                                 <!-- Top Row: Reason + Score + Tech Stats -->
                                                 <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*, Auto, Auto">
                                                     <TextBlock Grid.Column="0" Text="{Binding ShortReason}" Foreground="{Binding ReasonColor}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                     
                                                     <!-- Phase 1.0: Search Score Indicator -->
                                                     <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="8,0" VerticalAlignment="Center">
                                                         <Border Background="#222" CornerRadius="3" Width="60" Height="6" VerticalAlignment="Center">
                                                             <Border Background="{Binding ScoreColor}" CornerRadius="3" HorizontalAlignment="Left"
                                                                     Width="{Binding SearchScore, Converter={StaticResource PercentToWidthConverter}, ConverterParameter=60}"/>
                                                         </Border>
                                                         <TextBlock Text="{Binding SearchScore, StringFormat='{}{0:0}%'}" Foreground="#AAA" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                                     </StackPanel>
                                                     
                                                     <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" Margin="8,0,0,0">
                                                          <TextBlock Text="{Binding Bitrate, StringFormat='{}{0}kbps'}" Foreground="#888" FontSize="11"/>
                                                          <TextBlock Text="{Binding Format}" Foreground="#888" FontSize="11"/>
                                                          <TextBlock Text="{Binding Username, StringFormat='{}@{0}'}" Foreground="#555" FontSize="11"/>
                                                     </StackPanel>
                                                 </Grid>

                                                 <!-- Bottom Row: Filename -->
                                                 <TextBlock Grid.Row="1" Grid.Column="1" 
                                                            Text="{Binding Filename}" 
                                                            Foreground="#666" FontStyle="Italic" FontSize="10" 
                                                            TextTrimming="CharacterEllipsis" Margin="0,1,0,0"
                                                            ToolTip.Tip="{Binding Filename}"/>
                                             </Grid>
                                         </DataTemplate>
                                     </ItemsControl.ItemTemplate>
                                 </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Action -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <!-- View Log Button (Micro) -->
                            <Button Command="{Binding ViewLogCommand}" 
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    ToolTip.Tip="View Diagnostic Log"
                                    IsVisible="{Binding HasRejectionDetails}">
                                <PathIcon Data="{StaticResource document_text_regular}" Width="14" Height="14" Foreground="#666"/>
                            </Button>
                            
                            <Button Command="{Binding RetryCommand}" 
                                    Background="Transparent" 
                                    BorderThickness="1" BorderBrush="#2E7D32" 
                                    Foreground="#4CAF50"
                                    Padding="12,6" 
                                    CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <PathIcon Data="{StaticResource arrow_counterclockwise_regular}" Width="14" Height="14" Foreground="#4CAF50"/>
                                    <TextBlock Text="Retry" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    
    <Grid RowDefinitions="Auto,*">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#252526" Padding="24,20" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock Text="The In-Box" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <TextBlock Foreground="#A0A0A0" FontSize="13">
                            <Run Text="{Binding ActiveCount}"/>
                            <Run Text=" active" Foreground="#4CAF50"/>
                        </TextBlock>
                        <TextBlock Foreground="#A0A0A0" FontSize="13">
                            <Run Text="{Binding QueuedCount}"/>
                            <Run Text=" queued" Foreground="#FFA500"/>
                        </TextBlock>
                        <TextBlock Foreground="#A0A0A0" FontSize="13">
                            <Run Text="{Binding CompletedTodayCount}"/>
                            <Run Text=" completed" Foreground="#2196F3"/>
                        </TextBlock>
                        <TextBlock Text="{Binding GlobalSpeed, StringFormat='⚡ {0}'}" 
                                   Foreground="#00BCD4" 
                                   FontSize="13"
                                   FontWeight="SemiBold"/>

                        <!-- Phase 11: Global Search Status Indicator -->
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="12,0,0,0">
                            <Border Width="10" Height="10" CornerRadius="5" 
                                    Background="{Binding IsGlobalSearching, Converter={StaticResource BoolToColorConverter}}" 
                                    Classes.pulse="{Binding IsGlobalSearching}"
                                    VerticalAlignment="Center">
                                <Border.Styles>
                                    <Style Selector="Border.pulse">
                                        <Style.Animations>
                                            <Animation Duration="0:0:1" IterationCount="Infinite">
                                                <KeyFrame KeyTime="0:0:0"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                                <KeyFrame KeyTime="0:0:0.5"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                                                <KeyFrame KeyTime="0:0:1"><Setter Property="Opacity" Value="1"/></KeyFrame>
                                            </Animation>
                                        </Style.Animations>
                                    </Style>
                                </Border.Styles>
                            </Border>
                            <TextBlock Text="Search Engine" FontSize="11" Foreground="#888" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                
                <!-- Global Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <!-- Concurrency Control -->
                    <Border Background="#333" CornerRadius="6" Padding="12,4" Margin="0,0,12,0" BorderBrush="#444" BorderThickness="1">
                         <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                             <TextBlock Text="Max active:" VerticalAlignment="Center" Foreground="#CCC" FontSize="12"/>
                             <TextBlock Text="{Binding MaxConcurrentDownloads}" VerticalAlignment="Center" Foreground="#00BFFF" FontWeight="Bold" Width="20" TextAlignment="Center"/>
                             <Slider Width="100" 
                                     Minimum="1" Maximum="20" 
                                     Value="{Binding MaxConcurrentDownloads}" 
                                     TickPlacement="None"
                                     IsSnapToTickEnabled="True" 
                                     TickFrequency="1"
                                     VerticalAlignment="Center"/>
                         </StackPanel>
                    </Border>
                    <Button Command="{Binding PauseAllCommand}"
                            Background="#FFA500"
                            Foreground="White"
                            Padding="12,8"
                            CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="⏸" FontSize="14"/>
                            <TextBlock Text="Pause All" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ResumeAllCommand}"
                            Background="#4CAF50"
                            Foreground="White"
                            Padding="12,8"
                            CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="▶" FontSize="14"/>
                            <TextBlock Text="Resume All" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Phase 12.3: Bulk Selection Action Bar (Overlay) -->
        <Border Grid.Row="0" Background="#007ACC" Padding="24,20" BorderBrush="#005A9E" BorderThickness="0,0,0,1" IsVisible="{Binding HasSelection}">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="{Binding SelectedItems.Count}" FontSize="28" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="selected" FontSize="18" Foreground="#E0E0E0" VerticalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <Button Command="{Binding VipStartSelectedCommand}"
                            Background="White"
                            Foreground="#007ACC"
                            Padding="16,8"
                            CornerRadius="6"
                            FontWeight="Bold">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🚀" FontSize="16"/>
                            <TextBlock Text="VIP Start" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding ResumeSelectedCommand}"
                            Background="#4CAF50"
                            Foreground="White"
                            Padding="16,8"
                            CornerRadius="6"
                            FontWeight="Bold">
                         <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="▶" FontSize="14"/>
                            <TextBlock Text="Resume" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding PauseSelectedCommand}"
                            Background="#FFB74D"
                            Foreground="#4E342E" 
                            Padding="16,8"
                            CornerRadius="6"
                            FontWeight="Bold">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="⏸" FontSize="14"/>
                            <TextBlock Text="Pause" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding CancelSelectedCommand}"
                            Background="#D32F2F"
                            Foreground="White"
                            Padding="16,8"
                            CornerRadius="6"
                            FontWeight="Bold">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="✖" FontSize="14"/>
                            <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab Control -->
        <TabControl Grid.Row="1" Background="Transparent" Padding="0">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Padding" Value="16,12"/>
                </Style>
                <Style Selector="TabItem:selected">
                    <Setter Property="Foreground" Value="#4CAF50"/>
                </Style>
            </TabControl.Styles>

            <!-- Active Downloads Tab -->
            <TabItem Header="Active">
                <Grid RowDefinitions="Auto,*">
                    <!-- Global Status Indicator (Circuit Breaker / Connection Alerts) -->
                    <Border Grid.Row="0" 
                            IsVisible="{Binding IsGlobalStatusVisible}"
                            Background="{Binding IsGlobalStatusError, Converter={StaticResource BoolToErrorColorConverter}}"
                            Opacity="0.8"
                            Margin="16,16,16,0"
                            Padding="16,10"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="#44FFFFFF">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="⚠️" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding GlobalStatusMessage}" 
                                       Foreground="White" 
                                       FontWeight="SemiBold" 
                                       VerticalAlignment="Center"/>
                            <ProgressBar IsIndeterminate="True" 
                                         Width="100" 
                                         Height="2" 
                                         VerticalAlignment="Center" 
                                         Margin="12,0,0,0"
                                         IsVisible="{Binding IsGlobalStatusError}"/>
                        </StackPanel>
                    </Border>

                    <!-- Empty State -->
                    <Border Grid.Row="1" 
                            IsVisible="{Binding !HasAnyActiveOrQueued}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                        <StackPanel Spacing="12" HorizontalAlignment="Center">
                            <TextBlock Text="📥" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                            <TextBlock Text="No active downloads" 
                                       FontSize="18" 
                                       Foreground="#808080"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Downloads will appear here automatically" 
                                       FontSize="13" 
                                       Foreground="#606060"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Grouped List Layout (Active) - Split for Virtualization -->
                    <Grid Grid.Row="1" RowDefinitions="Auto, Auto, *" IsVisible="{Binding HasAnyActiveOrQueued}">
                        
                        <!-- Top Section: Active & Groups (Auto/Pinned) -->
                        <ScrollViewer Grid.Row="0" MaxHeight="500" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="24" Margin="16,16,16,8">
                                <!-- Phase 9: Swimlane: DIRECT ACTIVE (Searching or Downloading - First Results) -->
                                <StackPanel Spacing="8" IsVisible="{Binding ActiveTracks.Count}">
                                    <Border Background="#00BFFF" CornerRadius="4" Padding="12,4" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="🚀 DIRECT ACTIVE" FontSize="11" FontWeight="Bold" Foreground="Black"/>
                                            <TextBlock Text="{Binding ActiveTracks.Count}" FontSize="11" Foreground="#444" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                    <ItemsRepeater ItemsSource="{Binding ActiveTracks}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <c:StandardTrackRow Classes="card"/>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>

                                <!-- Swimlane: EXPRESS (Priority 0) -->
                                <StackPanel Spacing="8" IsVisible="{Binding ExpressGroups.Count}">
                                    <Border Background="#FFD700" CornerRadius="4" Padding="12,4" HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="🚀 EXPRESS" FontSize="11" FontWeight="Bold" Foreground="Black"/>
                                            <TextBlock Text="{Binding ExpressGroups.Count}" FontSize="11" Foreground="#444" FontWeight="Bold"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- Grouped EXPRESS cards -->
                                    <ItemsRepeater ItemsSource="{Binding ExpressGroups}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <c:DownloadGroupRow/>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>

                                <!-- Main Ongoing Section (Using StandardGroups) -->
                                <StackPanel Spacing="16" IsVisible="{Binding StandardGroups.Count}">
                                    <Border Background="#2D2D2D" CornerRadius="4" Padding="12,6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="🔥 ACTIVE GROUPS" FontSize="11" FontWeight="Bold" Foreground="#00BCD4"/>
                                            <TextBlock Text="{Binding StandardGroups.Count}" FontSize="11" Foreground="#888"/>
                                        </StackPanel>
                                    </Border>
                                    
                                    <ItemsRepeater ItemsSource="{Binding StandardGroups}">
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate>
                                                <c:DownloadGroupRow/>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Queue Header (Pinned) -->
                        <Border Grid.Row="1" Background="#2D2D2D" CornerRadius="4" Padding="12,6" Margin="16,8,16,8" IsVisible="{Binding QueuedDownloads.Count}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="⏳ QUEUE" FontSize="11" FontWeight="Bold" Foreground="#FFA500"/>
                                <TextBlock Text="{Binding QueuedDownloads.Count}" FontSize="11" Foreground="#888"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Queue List (Virtualized) -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" IsVisible="{Binding QueuedDownloads.Count}">
                            <ItemsRepeater ItemsSource="{Binding QueuedDownloads}" Margin="16,0,16,16">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Pause" Command="{Binding PauseCommand}" IsVisible="{Binding IsActive}"><MenuItem.Icon><PathIcon Data="{StaticResource pause_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                                                    <MenuItem Header="Resume" Command="{Binding ResumeCommand}" IsVisible="{Binding IsPaused}"><MenuItem.Icon><PathIcon Data="{StaticResource play_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                                                    <MenuItem Header="Cancel" Command="{Binding CancelCommand}"><MenuItem.Icon><PathIcon Data="{StaticResource dismiss_regular}" Width="16" Height="16"/></MenuItem.Icon></MenuItem>
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <c:StandardTrackRow Classes="card"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Completed Downloads Tab -->
            <TabItem Header="Completed">
                <Grid RowDefinitions="Auto,*">
                    <!-- Clear Button -->
                    <Border Grid.Row="0" Background="#1E1E1E" Padding="16,12" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1">
                        <Button Command="{Binding ClearCompletedCommand}"
                                HorizontalAlignment="Right"
                                Background="#333"
                                Foreground="White"
                                Padding="12,8"
                                CornerRadius="6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="🗑️" FontSize="12"/>
                                <TextBlock Text="Clear All" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </Border>

                    <!-- Empty State -->
                    <Border Grid.Row="1" 
                            IsVisible="{Binding !CompletedDownloads.Count}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                        <StackPanel Spacing="12" HorizontalAlignment="Center">
                            <TextBlock Text="✅" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                            <TextBlock Text="No completed downloads" 
                                       FontSize="18" 
                                       Foreground="#808080"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Completed List -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding CompletedDownloads}" ItemTemplate="{StaticResource DownloadItemTemplate}" Background="Transparent" BorderThickness="0">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListBox.Styles>
                    </ListBox>
                </Grid>
            </TabItem>

            <!-- Failed Downloads Tab -->
            <TabItem Header="Failed">
                <Grid RowDefinitions="Auto,*">
                    <!-- Actions Bar -->
                    <Border Grid.Row="0" Background="#1E1E1E" Padding="16,12" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                            <Button Command="{Binding RetryAllFailedCommand}"
                                    Background="#2E7D32"
                                    Foreground="White"
                                    Padding="12,8"
                                    CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="🔄" FontSize="12"/>
                                    <TextBlock Text="Retry All" FontSize="13"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding ClearFailedCommand}"
                                    Background="#333"
                                    Foreground="White"
                                    Padding="12,8"
                                    CornerRadius="6">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="🗑️" FontSize="12"/>
                                <TextBlock Text="Clear All" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        </StackPanel>
                    </Border>

                    <!-- Empty State -->
                    <Border Grid.Row="1" 
                            IsVisible="{Binding !FailedDownloads.Count}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                        <StackPanel Spacing="12" HorizontalAlignment="Center">
                            <TextBlock Text="💯" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                            <TextBlock Text="No failed downloads" 
                                       FontSize="18" 
                                       Foreground="#808080"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Failed List -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding FailedDownloads}" ItemTemplate="{StaticResource FailedDownloadItemTemplate}" Background="Transparent" BorderThickness="0">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListBox.Styles>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

