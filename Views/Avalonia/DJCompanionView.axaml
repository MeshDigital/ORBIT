<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.ViewModels"
             xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             xmlns:conv="clr-namespace:SLSKDONET.Views.Avalonia.Converters"
             mc:Ignorable="d" d:DesignWidth="1600" d:DesignHeight="900"
             x:Class="SLSKDONET.Views.Avalonia.DJCompanionView"
             x:DataType="vm:DJCompanionViewModel"
             Background="#1E1E1E"
             Foreground="White">

    <UserControl.Resources>
        <conv:BitmapValueConverter x:Key="BitmapValueConverter"/>
        <conv:RankColorConverter x:Key="RankColorConverter"/>
        <conv:ForensicColorConverter x:Key="ForensicColorConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="320,*,400">

        <!-- HEALTH BAR - Spans all columns -->
        <controls:SetlistHealthBar Grid.Row="0" Grid.ColumnSpan="3" DataContext="{Binding HealthBarViewModel}" Margin="0,0,0,8"/>

        <!-- HEADER -->
        <Border Grid.Row="1" Grid.ColumnSpan="3" Background="#252526" BorderBrush="#3E3E3E" BorderThickness="0,0,0,1" Padding="20,12">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Text="🎧 SET CURATOR" FontSize="15" FontWeight="Bold" LetterSpacing="2" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding HelpText}" FontSize="11" Foreground="#888" Margin="24,0" VerticalAlignment="Center" TextWrapping="Wrap"/>

                <Button Grid.Column="2" Command="{Binding TogglePlayCommand}"
                        Background="#FF4081"
                        Foreground="White"
                        CornerRadius="16"
                        Padding="14,6"
                        Margin="0,0,8,0">
                    <TextBlock Text="{Binding PlayButtonLabel}" FontWeight="SemiBold"/>
                </Button>

                <Button Grid.Column="3" Command="{Binding RunSetlistStressTestCommand}"
                        Content="🏥 Analyze Flow"
                        Background="#4EC9B0"
                        Padding="12,6"
                        CornerRadius="4"
                        ToolTip.Tip="Run setlist stress-test diagnostic"/>

                <Button Grid.Column="4" Content="📤 Export"
                        Background="#333"
                        Foreground="#CCC"
                        Padding="12,6"
                        CornerRadius="4"
                        Margin="8,0,0,0"
                        ToolTip.Tip="Export to Rekordbox/USB"/>
            </Grid>
        </Border>

        <!-- ╔════════════════════════════════════════════════════════════════╗ -->
        <!-- ║           LEFT PANEL: SETLIST (320px)                          ║ -->
        <!-- ╚════════════════════════════════════════════════════════════════╝ -->
        <Border Grid.Row="2" Grid.Column="0" Background="#1A1A1A" BorderBrush="#333" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*">
                <!-- Playlist Header -->
                <Border Grid.Row="0" Background="#252526" Padding="12,10" BorderBrush="#333" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ACTIVE SETLIST" FontSize="11" FontWeight="Bold" Foreground="#4EC9B0" LetterSpacing="1"/>
                            <TextBlock Text="{Binding SetlistTrackCount, StringFormat='{}{0} tracks'}" FontSize="10" Foreground="#666"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="+" FontSize="14" FontWeight="Bold"
                                Background="#333" Foreground="#888" Padding="8,2" CornerRadius="4"
                                ToolTip.Tip="Add tracks to setlist"/>
                    </Grid>
                </Border>

                <!-- Virtualized Setlist -->
                <ListBox Grid.Row="1" 
                         ItemsSource="{Binding CurrentSetlist}" 
                         SelectedItem="{Binding SelectedSetlistTrack}"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding IsSelected, Converter={StaticResource RankColorConverter}}"
                                    Padding="10,8" Margin="2" CornerRadius="6"
                                    BorderBrush="#333" BorderThickness="1">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <!-- Track Number -->
                                    <TextBlock Grid.Column="0" Text="{Binding Index, StringFormat='#{0}'}"
                                               FontSize="10" Foreground="#666" FontWeight="Bold"
                                               Width="24" VerticalAlignment="Center"/>

                                    <!-- Track Info -->
                                    <StackPanel Grid.Column="1" Spacing="2" Margin="8,0">
                                        <TextBlock Text="{Binding Title}" FontSize="11" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Artist}" FontSize="10" Foreground="#888"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <!-- Key/BPM/Energy Badges -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <!-- Key Badge -->
                                        <Border Background="#FF4081" CornerRadius="3" Padding="4,2" ToolTip.Tip="Key">
                                            <TextBlock Text="{Binding KeyDisplay}" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                        <!-- BPM Badge -->
                                        <Border Background="#4EC9B0" CornerRadius="3" Padding="4,2" ToolTip.Tip="BPM">
                                            <TextBlock Text="{Binding BpmDisplay}" FontSize="9" FontWeight="Bold" Foreground="#000"/>
                                        </Border>
                                        <!-- Energy Indicator -->
                                        <Border Background="#FFB300" CornerRadius="3" Padding="4,2" ToolTip.Tip="Energy">
                                            <TextBlock Text="{Binding EnergyLevel}" FontSize="9" FontWeight="Bold" Foreground="#000"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ╔════════════════════════════════════════════════════════════════╗ -->
        <!-- ║       CENTER PANEL: FOCUSED DECK (Flexible)                    ║ -->
        <!-- ╚════════════════════════════════════════════════════════════════╝ -->
        <Border Grid.Row="2" Grid.Column="1" Background="#1E1E1E" Padding="16">
            <Grid RowDefinitions="Auto,*,Auto,Auto">

                <!-- Now Playing Info -->
                <Border Grid.Row="0" Background="#252526" CornerRadius="12" Padding="16" Margin="0,0,0,12">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <!-- Album Art (smaller for focused deck) -->
                        <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True" Width="80" Height="80">
                            <Image Source="{Binding CurrentTrack.ArtworkBitmap, Converter={StaticResource BitmapValueConverter}}"
                                   Stretch="UniformToFill"/>
                        </Border>

                        <!-- Track Details -->
                        <StackPanel Grid.Column="1" Spacing="4" Margin="16,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentTrack.Title}" FontSize="18" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding CurrentTrack.Artist}" FontSize="14" Foreground="#888"/>
                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="🎹" FontSize="12"/>
                                    <TextBlock Text="{Binding CurrentTrack.KeyDisplay}" FontSize="12" Foreground="#FF4081" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="⏱️" FontSize="12"/>
                                    <TextBlock Text="{Binding CurrentTrack.BpmDisplay}" FontSize="12" Foreground="#4EC9B0" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="⚡" FontSize="12"/>
                                    <TextBlock Text="{Binding CurrentTrack.EnergyPercent, StringFormat='{}{0}%'}" FontSize="12" Foreground="#FFB300" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Duration / Time -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding CurrentTimeDisplay}" FontSize="24" FontWeight="Bold" Foreground="#4EC9B0" HorizontalAlignment="Right"/>
                            <TextBlock Text="{Binding TotalTimeDisplay}" FontSize="12" Foreground="#666" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- LARGE WAVEFORM - THE FOCUS -->
                <Border Grid.Row="1" Background="#0a0a0a" CornerRadius="12" Padding="8" MinHeight="220">
                    <Grid RowDefinitions="*,Auto">
                        <!-- Main Waveform with Cue Markers -->
                        <controls:WaveformControl Grid.Row="0"
                                                  Name="FocusedWaveform"
                                                  WaveformData="{Binding CurrentTrack.WaveformData}"
                                                  Cues="{Binding CurrentTrack.OrbitCues}"
                                                  PhraseSegments="{Binding CurrentTrack.PhraseSegments}"
                                                  EnergyCurve="{Binding CurrentTrack.EnergyCurve}"
                                                  Progress="{Binding PlaybackProgressNormalized}"
                                                  PlayheadBrush="#FF4081"
                                                  SeekCommand="{Binding SeekCommand}"
                                                  Foreground="#4EC9B0"
                                                  Background="#0a0a0a"
                                                  IsEditing="{Binding IsEditingCues}"
                                                  CueUpdatedCommand="{Binding CueUpdatedCommand}"
                                                  ToolTip.Tip="Click to seek, Shift+Click to edit cues"/>

                        <!-- Playback Progress Bar -->
                        <ProgressBar Grid.Row="1" Value="{Binding PlaybackProgress}" Maximum="100" 
                                     Height="4" Background="#333" Foreground="#FF4081" CornerRadius="2" Margin="0,8,0,0"/>
                    </Grid>
                </Border>

                <!-- HOT CUE BUTTONS -->
                <Border Grid.Row="2" Background="#252526" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                    <Grid ColumnDefinitions="Auto,*">
                        <TextBlock Grid.Column="0" Text="HOT CUES" FontSize="11" FontWeight="Bold" Foreground="#888" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ItemsControl Grid.Column="1" ItemsSource="{Binding CurrentTrack.CuePoints}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding $parent[UserControl].DataContext.JumpToCueCommand}"
                                            CommandParameter="{Binding}"
                                            Background="{Binding ColorHex}"
                                            Foreground="White"
                                            FontSize="10"
                                            FontWeight="Bold"
                                            Padding="10,6"
                                            CornerRadius="4"
                                            ToolTip.Tip="{Binding Role}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="{Binding Index, StringFormat='CUE {0}'}"/>
                                            <TextBlock Text="{Binding TimestampDisplay}" Foreground="#CCC" FontSize="9"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <!-- Transport Controls -->
                <Border Grid.Row="3" Background="#252526" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
                        <Button Content="⏮️" FontSize="18" Background="Transparent" BorderThickness="0" Padding="8" ToolTip.Tip="Previous Track"/>
                        <Button Command="{Binding TogglePlayCommand}" FontSize="24" Background="#FF4081" Foreground="White"
                                Padding="16,8" CornerRadius="24">
                            <TextBlock Text="{Binding PlayButtonIcon}" FontSize="18"/>
                        </Button>
                        <Button Content="⏭️" FontSize="18" Background="Transparent" BorderThickness="0" Padding="8" ToolTip.Tip="Next Track"/>
                        
                        <!-- Cue Edit Toggle -->
                        <Border Background="{Binding IsEditingCues, Converter={StaticResource RankColorConverter}}" CornerRadius="4" Padding="8,4" Margin="24,0,0,0">
                            <ToggleButton IsChecked="{Binding IsEditingCues}" Background="Transparent" BorderThickness="0">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="✏️"/>
                                    <TextBlock Text="EDIT CUES" FontSize="10" FontWeight="Bold"/>
                                </StackPanel>
                            </ToggleButton>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ╔════════════════════════════════════════════════════════════════╗ -->
        <!-- ║        RIGHT PANEL: SET INTELLIGENCE (400px)                   ║ -->
        <!-- ╚════════════════════════════════════════════════════════════════╝ -->
        <Border Grid.Row="2" Grid.Column="2" Background="#0a0a0a" BorderBrush="#333" BorderThickness="1,0,0,0">
            <Grid RowDefinitions="Auto,*">
                <!-- Header -->
                <Border Grid.Row="0" Background="#1A1A1A" Padding="16,12" BorderBrush="#333" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="🧠 SET INTELLIGENCE" FontSize="12" FontWeight="Bold" Foreground="#4EC9B0" LetterSpacing="1"/>
                        <TextBlock Text="Flow analysis and recommendations" FontSize="10" Foreground="#666"/>
                    </StackPanel>
                </Border>

                <!-- Intelligence Content -->
                <ScrollViewer Grid.Row="1" Padding="12">
                    <StackPanel Spacing="12">

                        <!-- Overall Health Score -->
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="SET HEALTH" FontSize="10" FontWeight="Bold" Foreground="#888"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SetHealthScore, StringFormat='{}{0}%'}" 
                                               FontSize="18" FontWeight="Bold" Foreground="#4EC9B0"/>
                                </Grid>
                                <ProgressBar Value="{Binding SetHealthScore}" Maximum="100" Height="6" 
                                             Background="#333" Foreground="#4EC9B0" CornerRadius="3"/>
                            </StackPanel>
                        </Border>

                        <!-- Issues Section -->
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="12" IsVisible="{Binding HasIssues}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="⚠️ ISSUES DETECTED" FontSize="10" FontWeight="Bold" Foreground="#FFB300"/>

                                <!-- Key Clashes -->
                                <ItemsControl ItemsSource="{Binding KeyClashes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#2a1a1a" CornerRadius="4" Padding="8" Margin="0,2">
                                                <StackPanel Spacing="2">
                                                    <TextBlock FontSize="10" Foreground="#FF6B6B">
                                                        <Run Text="🎹 Key Clash: "/>
                                                        <Run Text="{Binding TrackA}" FontWeight="Bold"/>
                                                        <Run Text=" → "/>
                                                        <Run Text="{Binding TrackB}" FontWeight="Bold"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Description}" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Energy Gaps -->
                                <ItemsControl ItemsSource="{Binding EnergyGaps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1a2a1a" CornerRadius="4" Padding="8" Margin="0,2">
                                                <StackPanel Spacing="2">
                                                    <TextBlock FontSize="10" Foreground="#FFB300">
                                                        <Run Text="⚡ Energy Gap at Track "/>
                                                        <Run Text="{Binding TrackIndex}" FontWeight="Bold"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Description}" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Vocal Clashes -->
                                <ItemsControl ItemsSource="{Binding VocalClashes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1a1a2a" CornerRadius="4" Padding="8" Margin="0,2">
                                                <StackPanel Spacing="2">
                                                    <TextBlock FontSize="10" Foreground="#E040FB">
                                                        <Run Text="🎤 Vocal Overlap: "/>
                                                        <Run Text="{Binding TrackA}" FontWeight="Bold"/>
                                                        <Run Text=" + "/>
                                                        <Run Text="{Binding TrackB}" FontWeight="Bold"/>
                                                    </TextBlock>
                                                    <TextBlock Text="Consider using instrumental version or stems" FontSize="9" Foreground="#888"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- AI Recommendations -->
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="💡 AI RECOMMENDATIONS" FontSize="10" FontWeight="Bold" Foreground="#4EC9B0"/>

                                <ItemsControl ItemsSource="{Binding MixingAdvice}" MaxHeight="200">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0a0a0a" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Title}" FontSize="10" FontWeight="SemiBold" Foreground="#FF4081"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="9" Foreground="#AAA" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Bridge Track Suggestions -->
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="12" IsVisible="{Binding HasBridgeSuggestions}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="🌉 BRIDGE SUGGESTIONS" FontSize="10" FontWeight="Bold" Foreground="#FFB300"/>
                                <TextBlock Text="Insert these tracks to fix energy gaps:" FontSize="9" Foreground="#888"/>

                                <ItemsControl ItemsSource="{Binding ForensicInspectorViewModel.RescueSuggestions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#0a0a0a" CornerRadius="4" Padding="8" Margin="0,4,0,0" 
                                                    BorderBrush="#FFB300" BorderThickness="1">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <StackPanel Grid.Column="0" Spacing="2">
                                                        <TextBlock Text="{Binding TargetTrack.Title}" FontSize="10" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding TargetTrack.Artist}" FontSize="9" Foreground="#888"/>
                                                        <TextBlock Text="{Binding WhyItFitsFull}" FontSize="8" Foreground="#666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="INSERT"
                                                            Command="{Binding $parent[UserControl].DataContext.ForensicInspectorViewModel.ApplyRescueTrackCommand}"
                                                            Background="#FFB300"
                                                            Foreground="#000"
                                                            FontSize="9"
                                                            FontWeight="Bold"
                                                            Padding="8,4"
                                                            CornerRadius="4"
                                                            VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- No Issues State -->
                        <Border Background="#1A2A1A" CornerRadius="8" Padding="16" IsVisible="{Binding !HasIssues}">
                            <StackPanel HorizontalAlignment="Center" Spacing="8">
                                <TextBlock Text="✅" FontSize="32" HorizontalAlignment="Center"/>
                                <TextBlock Text="Set looks great!" FontSize="14" FontWeight="Bold" Foreground="#00E676" HorizontalAlignment="Center"/>
                                <TextBlock Text="No harmonic clashes or energy issues detected" FontSize="10" Foreground="#888" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
