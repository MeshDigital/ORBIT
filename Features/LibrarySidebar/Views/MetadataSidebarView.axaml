<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.Features.LibrarySidebar.ViewModels"
             mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="800"
             x:Class="SLSKDONET.Features.LibrarySidebar.Views.MetadataSidebarView"
             x:DataType="vm:MetadataSidebarViewModel">
    <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Margin="16" Spacing="8">
            <TextBlock Text="Metadata Editor" FontSize="18" FontWeight="SemiBold" Foreground="#3B82F6"/>
            <TextBlock Text="Manual tag editing and artwork management." 
                       TextWrapping="Wrap" FontSize="12" Foreground="#888"/>
        </StackPanel>
        
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="16" Spacing="12">
                <!-- Form fields will go here in Phase 3 -->
                <TextBlock Text="Editor active" HorizontalAlignment="Center" Foreground="#555"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
