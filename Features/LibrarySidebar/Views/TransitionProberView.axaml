<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.Features.LibrarySidebar.ViewModels"
             xmlns:conv="clr-namespace:SLSKDONET.Views.Avalonia.Converters"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:Class="SLSKDONET.Features.LibrarySidebar.Views.TransitionProberView"
             x:DataType="vm:TransitionProberViewModel">
    
    <UserControl.Resources>
        <conv:SyncColorConverter x:Key="SyncColorConverter"/>
    </UserControl.Resources>
    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Header -->
        <TextBlock Text="TRANSITION PROBER" FontSize="14" FontWeight="Bold" LetterSpacing="2" Margin="20" Opacity="0.8"/>
        
        <!-- Mashup Sandbox Control Panel -->
        <Border Grid.Row="1" Background="#1A000000" BorderBrush="#33FFFFFF" BorderThickness="0,1" Padding="20,15" BoxShadow="0 4 20 #1A000000">
            <StackPanel Spacing="15">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="MASHUP SANDBOX" FontWeight="SemiBold" FontSize="12" Foreground="#4EC9B0"/>
                        <TextBlock Text="{Binding MashupStatus}" FontSize="10" Opacity="0.6" Margin="0,4,0,0"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1" 
                            Command="{Binding CommitSandboxCommand}"
                            ToolTip.Tip="Commit current stem blend settings to library"
                            Background="Transparent" BorderThickness="0" Margin="0,0,10,0"
                            IsVisible="{Binding IsAuditioning}">
                        <PathIcon Data="{StaticResource save_regular}" Width="16" Opacity="0.6"/>
                    </Button>

                    <ToggleButton Grid.Column="2" 
                                   IsChecked="{Binding IsAuditioning}" 
                                   Command="{Binding ToggleAuditionCommand}"
                                   Classes="SandboxToggle">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource headphones_regular}" Width="16"/>
                            <TextBlock Text="AUDITION"/>
                        </StackPanel>
                    </ToggleButton>
                </Grid>

                <!-- Vocal Hazard Meter -->
                <StackPanel IsVisible="{Binding IsAuditioning}" Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="VOCAL CLASH RISK" FontSize="10" Opacity="0.8"/>
                        <TextBlock Grid.Column="1" Text="{Binding HazardScore, StringFormat={}{0:P0}}" FontSize="10" FontWeight="Bold"/>
                    </Grid>
                    <ProgressBar Value="{Binding HazardScore}" Maximum="1.0" Height="4" Background="#333" Foreground="#FF4081" CornerRadius="2"/>
                    
                    <Button Command="{Binding ResolveClashCommand}"
                            Background="#40FF4081" 
                            BorderBrush="#FF4081" 
                            BorderThickness="1"
                            HorizontalAlignment="Stretch" 
                            HorizontalContentAlignment="Center"
                            Padding="0,8"
                            CornerRadius="6">
                         <Button.Styles>
                            <Style Selector="Button:hover">
                                <Setter Property="Background" Value="#60FF4081"/>
                                <Setter Property="RenderTransform" Value="scale(1.02)"/>
                            </Style>
                        </Button.Styles>
                        <Button.IsVisible>
                            <Binding Path="HazardScore" Converter="{StaticResource GreaterThanThreshold}">
                                <Binding.ConverterParameter>
                                    <x:Double>0.01</x:Double>
                                </Binding.ConverterParameter>
                            </Binding>
                        </Button.IsVisible>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <PathIcon Data="{StaticResource sparkles_regular}" Width="14"/>
                            <TextBlock Text="AUTO-RESOLVE CLASH" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Deck Display -->
        <ScrollViewer Grid.Row="2" Padding="15">
            <StackPanel Spacing="20">
                <!-- Deck A -->
                <Border Background="#1AFFFFFF" CornerRadius="12" Padding="15" BorderBrush="#22FFFFFF" BorderThickness="1">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Width="60" Height="60" CornerRadius="4" ClipToBounds="True">
                             <Image Source="{Binding PrimaryTrack.Artwork.Image}" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="15,0">
                            <TextBlock Text="DECK A (LEAD)" FontSize="10" Opacity="0.5" FontWeight="Bold"/>
                            <TextBlock Text="{Binding PrimaryTrack.Title}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding PrimaryTrack.Artist}" FontSize="12" Opacity="0.7"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="#204EC9B0" Padding="8,4" CornerRadius="4" VerticalAlignment="Center">
                             <TextBlock Text="{Binding PrimaryTrack.CamelotKey}" Foreground="#4EC9B0" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>

                <PathIcon Data="{StaticResource arrow_repeat_all_regular}" Width="24" Opacity="0.3" HorizontalAlignment="Center"/>

                <!-- Deck B -->
                <Border Background="#1AFFFFFF" CornerRadius="12" Padding="15" BorderBrush="#22FFFFFF" BorderThickness="1">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Border Width="60" Height="60" CornerRadius="4" ClipToBounds="True">
                             <Image Source="{Binding SecondaryTrack.Artwork.Image}" Stretch="UniformToFill"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="15,0">
                            <TextBlock Text="DECK B (CANDIDATE)" FontSize="10" Opacity="0.5" FontWeight="Bold"/>
                            <TextBlock Text="{Binding SecondaryTrack.Title}" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding SecondaryTrack.Artist}" FontSize="12" Opacity="0.7"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="#204EC9B0" Padding="8,4" CornerRadius="4" VerticalAlignment="Center">
                             <TextBlock Text="{Binding SecondaryTrack.CamelotKey}" Foreground="#4EC9B0" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3" Height="40" Background="#111" Padding="15,0">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="READY TO MIX" FontSize="10" Opacity="0.5" IsVisible="{Binding !IsSyncing}"/>
                    <TextBlock Text="SYNCING DECKS..." FontSize="10" Foreground="#F59E0B" FontWeight="Bold" IsVisible="{Binding IsSyncing}"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <Ellipse Width="6" Height="6" Fill="{Binding IsSyncing, Converter={StaticResource SyncColorConverter}}"/>
                    <TextBlock Text="ENGINE ONLINE" FontSize="10" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
