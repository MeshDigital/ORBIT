<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.Features.LibrarySidebar.ViewModels"
             mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="800"
             x:Class="SLSKDONET.Features.LibrarySidebar.Views.ForensicSidebarView"
             x:DataType="vm:ForensicSidebarViewModel">
    <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Margin="16" Spacing="8">
            <TextBlock Text="Forensic Repair" FontSize="18" FontWeight="SemiBold" Foreground="#F59E0B"/>
            <TextBlock Text="Deep analysis and semi-automated metadata recovery for low-confidence tracks." 
                       TextWrapping="Wrap" FontSize="12" Foreground="#888"/>
        </StackPanel>
        
        <Border Grid.Row="1" Margin="16" BorderBrush="#F59E0B" BorderThickness="1,1,1,1" CornerRadius="8" Opacity="0.6">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <TextBlock Text="🔬" FontSize="32" HorizontalAlignment="Center"/>
                <TextBlock Text="Forensic toolset loading..." Foreground="#AAA"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
