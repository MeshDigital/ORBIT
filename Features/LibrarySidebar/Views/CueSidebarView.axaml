<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.Features.LibrarySidebar.ViewModels"
             xmlns:conv="clr-namespace:SLSKDONET.Converters"
             mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="600"
             x:Class="SLSKDONET.Features.LibrarySidebar.Views.CueSidebarView"
             x:DataType="vm:CueSidebarViewModel">

    <UserControl.Resources>
        <conv:PhraseTypeToColorConverter x:Key="PhraseColorConverter" />
        <conv:BoolOpacityConverter x:Key="BoolOpacityConverter" />
        <conv:MathMultiplyConverter x:Key="MathMultiplyConverter" />
        <conv:StringToBrushConverter x:Key="StringToBrushConverter" />
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Animation for the analyzing state pulse -->
        <Style Selector="TextBlock.pulsing">
            <Style.Animations>
                <Animation Duration="0:0:1.5" IterationCount="Infinite" Easing="SineEaseInOut">
                    <KeyFrame KeyTime="0:0:0">
                        <Setter Property="Opacity" Value="0.4"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:0.75">
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                    <KeyFrame KeyTime="0:0:1.5">
                        <Setter Property="Opacity" Value="0.4"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <!-- Phrase Row Hover & Active Transitions -->
        <Style Selector="ListBoxItem.phraseRow">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.phraseContainer">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <ThicknessTransition Property="Padding" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.activePhrase">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="BorderBrush" Value="{Binding Type, Converter={StaticResource PhraseColorConverter}}"/>
            <Setter Property="BorderThickness" Value="2,0,0,0"/>
        </Style>

        <Style Selector="Border.ghostPhrase">
            <Setter Property="Background" Value="#05FFFFFF"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        <!-- Header Section -->
        <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,0,0,1" Padding="16,12">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <PathIcon Data="{StaticResource location_pin_regular}" Width="16" Height="16" Foreground="#AAA"/>
                <TextBlock Text="CUE &amp; PHRASE INSPECTOR" 
                           FontSize="11" FontWeight="Bold" 
                           Foreground="#888" 
                           VerticalAlignment="Center"
                           LetterSpacing="1"/>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            
            <!-- 1. EMPTY / ANALYSIS STATE -->
            <StackPanel IsVisible="{Binding !HasPhrases}" 
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Center" 
                        Spacing="24"
                        Margin="32">
                
                <Grid Width="120" Height="120">
                    <Ellipse Stroke="#222" StrokeThickness="4" StrokeDashArray="4,2"/>
                    <PathIcon Data="{StaticResource location_pin_regular}" 
                              Width="48" Height="48" 
                              Foreground="#444" 
                              Opacity="0.5"/>
                </Grid>

                <StackPanel Spacing="8" IsVisible="{Binding !IsAnalyzing}">
                    <TextBlock Text="No Structure Detected" 
                               FontWeight="SemiBold" FontSize="16" 
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Run AI phrasing analysis to visualize energy levels and transition points." 
                               TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="#888" FontSize="12"/>
                </StackPanel>

                <StackPanel Spacing="16" IsVisible="{Binding IsAnalyzing}">
                    <TextBlock Text="Detecting Structure..." 
                               Classes="pulsing"
                               FontWeight="SemiBold" FontSize="16" 
                               HorizontalAlignment="Center"
                               Foreground="#1DB954"/>
                    <ProgressBar IsIndeterminate="True" 
                                Height="2" MinWidth="180"
                                Foreground="#1DB954" Background="#222"/>
                </StackPanel>

                <Button Command="{Binding TriggerAnalysisCommand}"
                        IsVisible="{Binding !IsAnalyzing}"
                        HorizontalAlignment="Center"
                        Padding="24,10"
                        Background="#1DB954"
                        Foreground="White"
                        CornerRadius="20">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="{StaticResource play_regular}" Width="12" Height="12"/>
                        <TextBlock Text="Analyze Track Structure" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- 2. TIMELINE STATE -->
            <ScrollViewer IsVisible="{Binding HasPhrases}" 
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="1" Margin="0,4">
                    
                    <!-- Phrases Collection -->
                    <ItemsControl ItemsSource="{Binding Phrases}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:PhraseItemViewModel">
                                <Button Command="{Binding ((vm:CueSidebarViewModel)DataContext).SeekToPhraseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" BorderThickness="0" Padding="0"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                    <Grid>
                                        <Rectangle IsVisible="{Binding IsGhost}"
                                               Stroke="#33FFFFFF" 
                                               StrokeDashArray="4,2" 
                                               StrokeThickness="1"
                                               Margin="2" 
                                               RadiusX="4" RadiusY="4"/>
                                        
                                        <Border Classes="phraseContainer"
                                                Classes.activePhrase="{Binding IsActive}"
                                                Classes.ghostPhrase="{Binding IsGhost}"
                                                Padding="16,12"
                                                Background="#0AFFFFFF">
                                        <Grid ColumnDefinitions="4,*,Auto">
                                            <!-- Type Accent -->
                                            <Border Grid.Column="0" 
                                                    Width="3" CornerRadius="1"
                                                    VerticalAlignment="Stretch"
                                                    Background="{Binding Type, Converter={StaticResource PhraseColorConverter}}"/>
                                            
                                            <!-- Info -->
                                            <StackPanel Grid.Column="1" Margin="12,0" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Label}" 
                                                               FontWeight="Bold" 
                                                               FontSize="13"/>
                                                    <Border IsVisible="{Binding IsGhost}"
                                                            Background="#1AFFFFFF"
                                                            Padding="6,1" CornerRadius="4">
                                                        <TextBlock Text="AI SUGGESTION" FontSize="8" FontWeight="Bold" Foreground="#4CAF50"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding BarsLabel}" 
                                                           FontSize="11" 
                                                           Foreground="#666"/>
                                            </StackPanel>

                                            <!-- Micro-Graph -->
                                            <ItemsControl Grid.Column="2" 
                                                          ItemsSource="{Binding EnergyLevels}"
                                                          VerticalAlignment="Center">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="2" Height="20"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="x:Double">
                                                        <Border Width="3" 
                                                                CornerRadius="1"
                                                                VerticalAlignment="Bottom"
                                                                Background="{Binding $parent[Border].((vm:PhraseItemViewModel)DataContext).Type, Converter={StaticResource PhraseColorConverter}}"
                                                                Height="{Binding, Converter={StaticResource MathMultiplyConverter}, ConverterParameter=20}"
                                                                Opacity="{Binding}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="16,8" Background="#222"/>

                    <!-- Cues Title -->
                    <TextBlock Text="LANDMARKS &amp; CUES" 
                               Margin="16,8,16,8" 
                               FontSize="10" FontWeight="Bold" 
                               Foreground="#555" LetterSpacing="1"/>

                    <!-- Cues Collection -->
                    <ItemsControl ItemsSource="{Binding Cues}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CueItemViewModel">
                                <Border Padding="16,8" Background="Transparent">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <!-- Color Circle -->
                                        <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,12,0"
                                                 Fill="{Binding Color, Converter={StaticResource StringToBrushConverter}}"/>

                                        <!-- Label & IsGhost -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{Binding Label}" FontSize="12" Foreground="#CCC"/>
                                            <Border IsVisible="{Binding IsGhost}"
                                                    Background="#1AFFFFFF"
                                                    Padding="6,1" CornerRadius="4">
                                                <TextBlock Text="AI GHOST" FontSize="8" FontWeight="Bold" Foreground="#666"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Timestamp -->
                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding TimestampLabel}" 
                                                   FontSize="11" Foreground="#555"
                                                   FontFamily="Consolas, Monospace"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>

            <!-- Bottom Action Tray (Optional/Future) -->
        </Grid>
    </Grid>
</UserControl>
