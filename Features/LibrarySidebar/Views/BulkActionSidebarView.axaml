<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.Features.LibrarySidebar.ViewModels"
             mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="800"
             x:Class="SLSKDONET.Features.LibrarySidebar.Views.BulkActionSidebarView"
             x:DataType="vm:BulkActionSidebarViewModel">
    <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Margin="16" Spacing="8">
            <TextBlock Text="Bulk Operations" FontSize="18" FontWeight="SemiBold" Foreground="#FF5D5D"/>
            <TextBlock Text="Apply changes to all selected tracks simultaneously." 
                       TextWrapping="Wrap" FontSize="12" Foreground="#888"/>
        </StackPanel>
        
        <!-- Action list will go here in Phase 3 -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="16" Spacing="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="CORE ACTIONS" FontSize="11" FontWeight="Bold" Foreground="#666"/>
                    <Button HorizontalAlignment="Stretch" Content="Analyze Selected" Classes="danger"/>
                    <Button HorizontalAlignment="Stretch" Content="Move to Folder..."/>
                    <Button HorizontalAlignment="Stretch" Content="Remove from Library" Classes="danger"/>
                </StackPanel>

                <Separator Background="#333"/>

                <StackPanel Spacing="10">
                    <TextBlock Text="EXPORT ENGINE" FontSize="11" FontWeight="Bold" Foreground="#666"/>
                    <Border Background="#2A2A2D" BorderBrush="#3E3E3E" BorderThickness="1" CornerRadius="8" Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Rekordbox XML" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="Export selected tracks into a Pioneer-compatible XML including all AI cues, keys, and energy levels." 
                                       TextWrapping="Wrap" FontSize="11" Foreground="#AAA"/>
                            
                            <Button HorizontalAlignment="Stretch" 
                                    Command="{Binding ExportCommand}"
                                    Margin="0,8,0,0"
                                    Classes="primary"
                                    Height="40">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="📂" VerticalAlignment="Center"/>
                                    <TextBlock Text="Export Selected Tracks" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
