<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.Features.LibrarySidebar.ViewModels"
             mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="800"
             x:Class="SLSKDONET.Features.LibrarySidebar.Views.SimilaritySidebarView"
             x:DataType="vm:SimilaritySidebarViewModel">
    <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Margin="16" Spacing="8">
            <TextBlock Text="Discovery Mode" FontSize="18" FontWeight="SemiBold" Foreground="#4EC9B0"/>
            <TextBlock Text="Finding tracks that match the energy, mood, and key of your selection." 
                       TextWrapping="Wrap" FontSize="12" Foreground="#888"/>
        </StackPanel>
        
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Matches}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="12,4" Padding="12" Background="#1E1E1E" CornerRadius="8">
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Artist}" FontSize="11" Foreground="#888" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    
                                    <Border Grid.Column="1" Background="{Binding BadgeColor}" CornerRadius="6" Padding="8,4" VerticalAlignment="Top">
                                        <TextBlock Text="{Binding ConfidenceLabel}" 
                                                   FontSize="14" FontWeight="Bold" 
                                                   Foreground="Black"/>
                                    </Border>
                                </Grid>

                                <!-- Markers Row -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="#2D2D2D" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="{Binding Key}" FontSize="10" Foreground="#4EC9B0"/>
                                    </Border>
                                    <Border Background="#2D2D2D" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="{Binding Bpm, StringFormat={}{0} BPM}" FontSize="10" Foreground="#DCDCAA"/>
                                    </Border>
                                    <Border IsVisible="{Binding VibeMatch}" Background="#CE9178" CornerRadius="4" Padding="6,2">
                                        <TextBlock Text="✨ Vibe Match" FontSize="10" Foreground="Black"/>
                                    </Border>
                                </StackPanel>

                                <!-- Match Tags (Transparency) -->
                                <ItemsControl ItemsSource="{Binding MatchTags}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="10" Foreground="#66D9EF" Opacity="0.8" Margin="0,1"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="1" Background="#AA000000" IsVisible="{Binding IsLoading}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressBar IsIndeterminate="True" Width="100"/>
                <TextBlock Text="Calculated Sonic Proximity..." Foreground="#888" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
