<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.Features.LibrarySidebar.ViewModels"
             xmlns:controls="clr-namespace:SLSKDONET.Views.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="800"
             x:Class="SLSKDONET.Features.LibrarySidebar.Views.SimilaritySidebarView"
             x:DataType="vm:SimilaritySidebarViewModel">
    <Grid RowDefinitions="Auto,*">
        <!-- Playlist Smart Actions -->
        <Border Grid.Row="0" Background="#1A1A1A" BorderBrush="#333" BorderThickness="0,0,0,1" Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Command="{Binding HarmonizePlaylistCommand}" 
                        Background="#334EC9B0" Padding="12,6" CornerRadius="6"
                        ToolTip.Tip="Find best sonic matches for every track in the current playlist">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="🪄" VerticalAlignment="Center"/>
                        <TextBlock Text="Smart Fill" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button Command="{Binding UndoFillCommand}" 
                        Background="#33FF6666" Padding="12,6" CornerRadius="6"
                        ToolTip.Tip="Remove last batch-added tracks">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="↩" VerticalAlignment="Center"/>
                        <TextBlock Text="Undo" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding DiscoverMoreExternallyCommand}" 
                        Background="#3366D9EF" Padding="12,6" CornerRadius="6"
                        ToolTip.Tip="Find related tracks from Spotify/MusicBrainz and bridge to Soulseek Search">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="⛵" VerticalAlignment="Center"/>
                        <TextBlock Text="Discovery Bridge" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Loading Overlay (Higher Z-index) -->
        <Border Grid.Row="1" Background="#80000000" IsVisible="{Binding IsLoading}" ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <ProgressBar IsIndeterminate="True" Width="200" Height="2" Foreground="#00BFFF"/>
                <TextBlock Text="Analyzing Library Samples..." Foreground="#00BFFF" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1">
            <Grid Grid.IsSharedSizeScope="True">
                <ListBox ItemsSource="{Binding Matches}"
                     SelectedItem="{Binding SelectedMatch}"
                     Background="Transparent" BorderThickness="0">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="#334EC9B0"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="12,4" Padding="4" Background="#1E1E1E" CornerRadius="8" BorderBrush="#333" BorderThickness="1">
                            <StackPanel Spacing="2">
                                <!-- Standard Playable Row -->
                                <controls:StandardTrackRow DataContext="{Binding TrackVm}" IsCompact="True"/>
                                
                                <!-- Match Transparency & Breakdown -->
                                <Border Padding="12,2,12,8" Background="Transparent">
                                    <StackPanel Spacing="6">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <WrapPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <Border Background="#2D2D2D" CornerRadius="4" Padding="6,2" Margin="0,0,8,4">
                                                    <TextBlock Text="{Binding Key}" FontSize="10" Foreground="#4EC9B0"/>
                                                </Border>
                                                <Border Background="#2D2D2D" CornerRadius="4" Padding="6,2" Margin="0,0,8,4">
                                                    <TextBlock Text="{Binding Bpm, StringFormat={}{0} BPM}" FontSize="10" Foreground="#DCDCAA"/>
                                                </Border>
                                                <Border IsVisible="{Binding VibeMatch}" Background="#CE9178" CornerRadius="4" Padding="6,2" Margin="0,0,8,4">
                                                    <TextBlock Text="✨ Vibe Match" FontSize="10" Foreground="Black" FontWeight="SemiBold"/>
                                                </Border>
                                            </WrapPanel>
                                            
                                            <!-- Confidence Badge -->
                                            <Border Grid.Column="1" Background="{Binding BadgeColor}" CornerRadius="6" Padding="8,2" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding ConfidenceLabel}" 
                                                         FontSize="11" FontWeight="Bold" 
                                                         Foreground="Black"/>
                                            </Border>
                                        </Grid>

                                        <!-- Detail Match Tags -->
                                        <ItemsControl ItemsSource="{Binding MatchTags}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#11FFFFFF" CornerRadius="4" Padding="4,2" Margin="0,2,4,2">
                                                        <TextBlock Text="{Binding}" FontSize="10" Foreground="#66D9EF" Opacity="0.8"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </ScrollViewer>

        <!-- Loading Overlay -->
        <Border Grid.Row="1" Background="#AA000000" IsVisible="{Binding IsLoading}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressBar IsIndeterminate="True" Width="100"/>
                <TextBlock Text="Calculated Sonic Proximity..." Foreground="#888" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
