<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:SLSKDONET.Features.LibrarySidebar.ViewModels"
             mc:Ignorable="d" d:DesignWidth="350" d:DesignHeight="800"
             x:Class="SLSKDONET.Features.LibrarySidebar.Views.SimilaritySidebarView"
             x:DataType="vm:SimilaritySidebarViewModel">
    <Grid RowDefinitions="Auto,*">
        <StackPanel Grid.Row="0" Margin="16" Spacing="8">
            <TextBlock Text="Discovery Mode" FontSize="18" FontWeight="SemiBold" Foreground="#4EC9B0"/>
            <TextBlock Text="Finding tracks that match the energy, mood, and key of your selection." 
                       TextWrapping="Wrap" FontSize="12" Foreground="#888"/>
        </StackPanel>
        
        <!-- Results list will go here in Phase 3 -->
        <Border Grid.Row="1" Margin="16" BorderBrush="#333" BorderThickness="1" CornerRadius="8">
            <TextBlock Text="Matches will appear here..." VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#555"/>
        </Border>
    </Grid>
</UserControl>
